---
import "@/styles/global.css";
import { Font } from "astro:assets";
import Footer from "@/components/Footer.astro";
import JsonLd from "@/components/JsonLd.astro";
import Navigation from "@/components/Navigation.astro";
import ScrollProgress from "@/components/ScrollProgress.astro";
import { SITE_DESCRIPTION, SITE_NAME } from "@/site.config";

interface Props {
  title: string;
  description?: string;
}

// Default the description to the site-wide one so every page has SEO/OG copy.
const { title, description = SITE_DESCRIPTION } = Astro.props;

const site = String(Astro.site);
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const siteGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${site}#website`,
      url: site,
      name: SITE_NAME,
      description: SITE_DESCRIPTION,
      publisher: { "@id": `${site}#organization` },
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: new URL("/search/?q={search_term_string}", Astro.site)
            .href,
        },
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "Organization",
      "@id": `${site}#organization`,
      name: `CGIAR ${SITE_NAME}`,
      url: site,
      parentOrganization: {
        "@type": "Organization",
        name: "CGIAR",
        url: "https://www.cgiar.org",
      },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/svg+xml" href="/cdh-favicon-29yr.svg">
    <link rel="icon" href="/CDH_favicon_29yr.ico">
    <meta name="generator" content={Astro.generator}>

    <title>{title}</title>
    {description && <meta content={description} name="description" />}
    <link rel="canonical" href={canonical}>
    <meta property="og:title" content={title}>
    {description && <meta content={description} property="og:description" />}
    <meta property="og:type" content="website">
    <meta property="og:site_name" content={SITE_NAME}>
    <meta property="og:url" content={canonical}>
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content={title}>
    {description && <meta content={description} name="twitter:description" />}

    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-serif" preload />

    <JsonLd data={siteGraph} />
    <slot name="head" />
  </head>
  <body>
    <ScrollProgress />
    <Navigation />
    <main class="page">
      <slot />
    </main>
    <Footer />

    <script>
    // Dress every shiki block with a header: language label + copy button
    for (const pre of document.querySelectorAll<HTMLPreElement>(
      "pre.astro-code",
    )) {
      const wrap = document.createElement("div");
      wrap.className = "code-block";
      const head = document.createElement("div");
      head.className = "code-head";
      const lang = document.createElement("span");
      lang.className = "mono code-lang";
      lang.textContent =
        pre.closest<HTMLElement>("[data-code-label]")?.dataset.codeLabel
        ?? pre.dataset.language
        ?? "code";
      const icon = (path: string) =>
        `<svg aria-hidden="true" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
      const copyIcon = icon(
        '<rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>',
      );
      const checkIcon = icon('<path d="M20 6 9 17l-5-5"/>');
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "code-copy";
      btn.setAttribute("aria-label", "Copy code");
      btn.innerHTML = copyIcon;
      btn.addEventListener("click", async () => {
        await navigator.clipboard.writeText(pre.innerText);
        btn.innerHTML = checkIcon;
        setTimeout(() => {
          btn.innerHTML = copyIcon;
        }, 1200);
      });
      head.append(lang, btn);
      pre.replaceWith(wrap);
      wrap.append(head, pre);
    }
    </script>
  </body>
</html>
