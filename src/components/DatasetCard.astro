---
// Typographic dataset card: glyph, serif title, tags line, mono meta row.
// Title/summary/tags are line-clamped so cards in a row stay symmetrical.
import type { DatasetSummary } from "@/lib/catalog";
import DataGlyph from "./DataGlyph.astro";

interface Props {
  dataset: DatasetSummary;
}

const { dataset: d } = Astro.props;
---

<article class="ds-card">
  <span class="label type">
    <DataGlyph size={13} type={d.type} />
    {d.type === "spatial" ? "Spatial" : "Non-spatial"}
  </span>
  <h3><a href={`/catalog/${d.id}/`}>{d.title}</a></h3>
  <p class="summary">{d.description}</p>
  {d.keywords.length > 0 && <p class="tags">tags: {d.keywords.join(", ")}</p>}
  <div class="meta mono">
    <span>{[d.coverage, d.resolution].filter(Boolean).join(" · ")}</span>
    <span>{[d.license, d.temporal].filter(Boolean).join(" · ")}</span>
  </div>
</article>

<style>
.ds-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 12px;
  height: 100%;
  padding: 22px 22px 18px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  transition:
    border-color 0.16s,
    box-shadow 0.16s,
    transform 0.16s;
}

.ds-card:hover {
  border-color: var(--cdh-blue-300);
  box-shadow: 0 10px 30px rgb(20 16 8 / 7%);
  transform: translateY(-2px);
}

.type {
  display: inline-flex;
  gap: 6px;
  align-items: center;
}

/* Bare colored icon — the boxed chip look stays for other DataGlyph uses */
.type :global(.glyph) {
  width: auto;
  height: auto;
  background: none;
  border-radius: 0;
}

h3 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  margin-top: 4px;
  overflow: hidden;
  -webkit-line-clamp: 3;
  font-size: 21px;
  font-weight: 500;
  line-height: 1.22;
}

/* Whole card is the click target for the title link */
h3 a {
  color: inherit;
}

h3 a::after {
  position: absolute;
  inset: 0;
  content: "";
}

h3 a:hover {
  color: var(--cdh-blue-700);
  text-decoration: none;
}

.summary {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  overflow: hidden;
  -webkit-line-clamp: 3;
  font-size: 14px;
  line-height: 1.55;
  color: var(--text-soft);
}

/* Tags sit at the bottom, flush against the meta row */
.tags {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  margin-top: auto;
  overflow: hidden;
  -webkit-line-clamp: 2;
  font-size: 11.5px;
  line-height: 1.5;
  color: var(--text-mute);
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 3px 8px;
  align-items: center;
  justify-content: space-between;
  padding-top: 14px;
  font-size: 11.5px;
  color: var(--text-mute);
  border-top: 1px solid var(--border);
}

/* No tags line? The meta row anchors to the bottom itself */
.summary + .meta {
  margin-top: auto;
}

/* Facts wrap as whole lines, never mid-token */
.meta span {
  white-space: nowrap;
}
</style>
