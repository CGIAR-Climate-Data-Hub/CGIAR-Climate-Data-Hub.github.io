---
// Spatial-extent preview: Natural Earth land on an Equal Earth projection,
// with the record's bbox. All paths are projected at build time — no JS.
import { extentMap as m } from "@/lib/map";

interface Props {
  bbox?: number[];
  label?: string;
  crs?: string;
}

const { bbox, label, crs = "EPSG:4326" } = Astro.props;
const box = bbox && m.bbox(bbox);
---

<figure>
  <svg
    aria-label={`Spatial extent${label ? `: ${label}` : ""}`}
    role="img"
    viewBox={`0 0 ${m.width} ${m.height}`}
  >
    <path d={m.sphere} fill="rgb(99 169 254 / 8%)"></path>
    <path
      d={m.graticule}
      fill="none"
      stroke="rgb(10 44 85 / 10%)"
      stroke-width="0.4"
    ></path>
    <path
      d={m.land}
      fill="rgb(10 44 85 / 14%)"
      stroke="rgb(10 44 85 / 35%)"
      stroke-linejoin="round"
      stroke-width="0.35"
    ></path>
    {box && <path d={box} fill="rgb(99 169 254 / 14%)" stroke="var(--cdh-blue-700)" stroke-dasharray="4 2" stroke-width="1"></path>}
  </svg>
  {label && <figcaption class="mono">{label} · {crs} · Equal Earth</figcaption>}
</figure>

<style>
figure {
  margin: 0;
  overflow: hidden;
  background: linear-gradient(180deg, var(--surface), var(--cdh-blue-50));
  border: 1px solid var(--cdh-blue-150);
  border-radius: 8px;
}

svg {
  display: block;
  width: 100%;
  height: auto;
  padding: 6px;
}

figcaption {
  padding: 6px 12px;
  font-size: 10px;
  color: var(--cdh-blue-800);
  border-top: 1px solid var(--cdh-blue-150);
}
</style>
