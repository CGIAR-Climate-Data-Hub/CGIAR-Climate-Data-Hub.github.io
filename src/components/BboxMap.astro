---
// Spatial-extent preview: Natural Earth land + the record's bbox(es). No JS.

import { projectLonLat } from "@/lib/coordinates";
import { landPath } from "@/lib/map";

interface Props {
  bboxes?: number[][];
  label?: string;
}

const { bboxes = [], label } = Astro.props;

const W = 300;
const H = 150;
const rects = bboxes.map((b) => {
  const [x1, y1] = projectLonLat(b[0], b[3], W, H);
  const [x2, y2] = projectLonLat(b[2], b[1], W, H);
  return { x: x1, y: y1, w: Math.max(2, x2 - x1), h: Math.max(2, y2 - y1) };
});
---

<figure>
  <svg
    aria-label={`Spatial extent${label ? `: ${label}` : ""}`}
    role="img"
    viewBox={`0 0 ${W} ${H}`}
  >
    <rect
      fill="var(--cdh-blue-300)"
      fill-opacity="0.06"
      height={H}
      width={W}
      x="0"
      y="0"
    ></rect>
    <path
      d={landPath(W, H)}
      fill="var(--cdh-blue-950)"
      fill-opacity="0.16"
      stroke="var(--cdh-blue-950)"
      stroke-linejoin="round"
      stroke-opacity="0.36"
      stroke-width="0.35"
    ></path>
    {rects.map((r) => <rect fill="var(--cdh-blue-300)" fill-opacity="0.14" height={r.h} stroke="var(--cdh-blue-700)" stroke-dasharray="4 2" stroke-width="1" width={r.w} x={r.x} y={r.y}></rect>)}
  </svg>
</figure>

<style>
figure {
  margin: 0;
  overflow: hidden;
  background: linear-gradient(180deg, var(--surface), var(--cdh-blue-50));
  border: 1px solid var(--cdh-blue-150);
  border-radius: var(--radius-lg);
}

svg {
  display: block;
  width: 100%;
  height: auto;
}
</style>
