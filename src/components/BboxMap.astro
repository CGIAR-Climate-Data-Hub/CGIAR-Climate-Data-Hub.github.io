---
// Spatial-extent preview: rough continent silhouettes + the record's bbox.
// Illustrative, not geographically precise — no map tiles, no JS.
interface Props {
  bbox?: number[];
  label?: string;
}

const { bbox, label } = Astro.props;

const W = 300;
const H = 150;
const toSvg = (lon: number, lat: number) => [
  ((lon + 180) / 360) * W,
  ((90 - lat) / 180) * H,
];

