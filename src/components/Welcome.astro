---
import astroLogo from "@/assets/astro.svg";
import background from "@/assets/background.svg";
---

<div id="container">
  <img id="background" src={background.src} alt="" fetchpriority="high">
  <main>
    <section id="hero">
      <a href="https://astro.build"
        ><img
          src={astroLogo.src}
          width="115"
          height="48"
          alt="Astro Homepage"
        ></a
      >
      <h1>Coming Soon! Climate Action Data Hub Website</h1>
      <h2>
        To get started, open the <code><pre>src/pages</pre></code> directory in
        your project.
      </h2>
      <section id="links">
        <a class="button" href="https://docs.astro.build"
          >Read the Astro docs</a
        >
      </section>
    </section>
  </main>
</div>

<style>
#background {
  position: fixed;
  top: 0;
  left: 0;
  z-index: -1;
  width: 100%;
  height: 100%;
  filter: blur(100px);
}

#container {
  height: 100%;
  font-family:
    Inter, Roboto, "Helvetica Neue", "Arial Nova", "Nimbus Sans", Arial,
    sans-serif;
}

main {
  display: flex;
  justify-content: center;
  height: 100%;
}

#hero {
  display: flex;
  flex-direction: column;
  align-items: start;
  justify-content: center;
  padding: 16px;
}

h1 {
  margin-top: 0.25em;
  font-size: 22px;
}

#links {
  display: flex;
  gap: 16px;
}

#links a {
  display: flex;
  align-items: center;
  padding: 10px 12px;
  color: #111827;
  text-decoration: none;
  transition: color 0.2s;
}

#links a:hover {
  color: rgb(78, 80, 86);
}

#links a svg {
  height: 1em;
  margin-left: 8px;
}

#links a.button {
  color: white;
  background: linear-gradient(83.21deg, #3245ff 0%, #bc52ee 100%);
  border-radius: 10px;
  box-shadow:
    inset 0 0 0 1px rgba(255, 255, 255, 0.12),
    inset 0 -2px 0 rgba(0, 0, 0, 0.24);
}

#links a.button:hover {
  color: rgb(230, 230, 230);
  box-shadow: none;
}

pre {
  margin: 0;
  font-family:
    ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, Consolas,
    "DejaVu Sans Mono", monospace;
  font-weight: normal;
  -webkit-text-fill-color: transparent;
  background: linear-gradient(14deg, #d83333 0%, #f041ff 100%);
  -webkit-background-clip: text;
  background-clip: text;
}

h2 {
  margin: 0 0 1em;
  font-size: 20px;
  font-weight: normal;
  color: #111827;
}

p {
  margin: 0;
  font-size: 16px;
  line-height: 24px;
  color: #4b5563;
  letter-spacing: -0.006em;
}

code {
  display: inline-block;
  padding: 6px 8px;
  background:
    linear-gradient(66.77deg, #f3cddd 0%, #f5cee7 100%) padding-box,
    linear-gradient(155deg, #d83333 0%, #f041ff 18%, #f5cee7 45%) border-box;
  border: 1px solid transparent;
  border-radius: 8px;
}

.box {
  padding: 16px;
  background: rgba(255, 255, 255, 1);
  border: 1px solid white;
  border-radius: 16px;
}

#news {
  position: absolute;
  right: 16px;
  bottom: 16px;
  max-width: 300px;
  text-decoration: none;
  backdrop-filter: blur(50px);
  transition: background 0.2s;
}

#news:hover {
  background: rgba(255, 255, 255, 0.55);
}

@media screen and (max-height: 368px) {
  #news {
    display: none;
  }
}

@media screen and (max-width: 768px) {
  #container {
    display: flex;
    flex-direction: column;
  }

  #hero {
    display: block;
    padding-top: 10%;
  }

  #links {
    flex-wrap: wrap;
  }

  #links a.button {
    padding: 14px 18px;
  }

  #news {
    right: 16px;
    bottom: 2.5rem;
    left: 16px;
    max-width: 100%;
  }

  h1 {
    line-height: 1.5;
  }
}
</style>
