---
// Program-blue reading-progress bar. Long-form pages only.
---

<div aria-hidden="true" class="scroll-progress">
  <div class="fill" data-scroll-progress></div>
</div>

<script>
const fill = document.querySelector<HTMLElement>("[data-scroll-progress]");
const onScroll = () => {
  const el = document.documentElement;
  const max = el.scrollHeight - el.clientHeight;
  if (fill)
    fill.style.width = `${max > 0 ? Math.min(100, (el.scrollTop / max) * 100) : 0}%`;
};
addEventListener("scroll", onScroll, { passive: true });
addEventListener("resize", onScroll, { passive: true });
onScroll();
</script>

<style>
.scroll-progress {
  position: fixed;
  top: 0;
  right: 0;
  left: 0;
  z-index: 60;
  height: 3px;
  pointer-events: none;
}

.fill {
  width: 0;
  height: 100%;
  background: linear-gradient(90deg, var(--cdh-blue-700), var(--cdh-blue-300));
  transition: width 0.08s linear;
}
</style>
