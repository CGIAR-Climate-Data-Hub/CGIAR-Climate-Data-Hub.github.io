---
import { getCollection, render } from "astro:content";
import ArticleToc from "@/components/ArticleToc.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import JsonLd from "@/components/JsonLd.astro";
import Layout from "@/layouts/Layout.astro";
import { allTutorials } from "@/lib/collections";
import { editUrl } from "@/lib/github";
import { SITE_NAME, SITE_REPO } from "@/site.config";

export async function getStaticPaths() {
  const entries = await allTutorials();
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Notebook tutorials offer the source for download / opening in Colab
const isNotebook = entry.collection === "notebookTutorials";
const notebookPath = `src/content/tutorials/${entry.id}.ipynb`;

// Resolve linked catalog records for the "Data" line
const catalog = await getCollection("catalog");
const datasets = entry.data.datasets.map((id) => ({
  id,
  title: catalog.find((c) => c.data.id === id)?.data.title ?? id,
}));

// "20 min" / "2 hrs" → ISO 8601 duration for schema.org timeRequired
const match = entry.data.time.match(/(\d+)\s*(min|hr|hour)/);
const timeRequired =
  match && (match[2] === "min" ? `PT${match[1]}M` : `PT${match[1]}H`);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["TechArticle", "LearningResource"],
  headline: entry.data.title,
  description: entry.data.description,
  url: new URL(`/tutorials/${entry.id}/`, Astro.site).href,
  audience: { "@type": "Audience", audienceType: entry.data.audience },
  ...(timeRequired && { timeRequired }),
  dateModified: entry.data.updated.toISOString().slice(0, 10),
  author: entry.data.author
    ? { "@type": "Person", name: entry.data.author }
    : { "@type": "Organization", name: `CGIAR ${SITE_NAME}` },
  isPartOf: { "@type": "WebSite", "@id": `${Astro.site}#website` },
};
---

<Layout
  description={entry.data.description}
  title={`${entry.data.title} — ${SITE_NAME}`}
>
  <JsonLd data={jsonLd} slot="head" />

  <div class="container narrow-grid">
    <article>
      <Breadcrumbs
        items={[{ label: "Hub", href: "/" }, { label: "Tutorials", href: "/tutorials/" }, { label: entry.data.title }]}
      />
      <div class="head">
        <span
          class:list={["pill", "dot", entry.data.audience === "Anyone" ? "spatial" : "warn"]}
        >
          {entry.data.audience}
        </span>
        <span class="pill">{entry.data.topic}</span>
        <span class="mono meta">
          {[
            entry.data.time,
            entry.data.format,
            entry.data.author && `by ${entry.data.author}`,
          ]
            .filter(Boolean)
            .join(" · ")}
        </span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="sub">{entry.data.description}</p>
      {datasets.length > 0 && (
        <p class="mono uses">
          Data:{" "}
          {datasets.map((ds, i) => (
            <>
              {i > 0 && ", "}
              <a href={`/catalog/${ds.id}/`}>{ds.title}</a>
            </>
          ))}
        </p>
      )}
      {isNotebook && (
        <div class="nb-actions">
          <a class="btn btn-ghost" download href={`/tutorials/${entry.id}.ipynb`}>
            Download notebook
          </a>
          <a
            class="btn btn-ghost"
            href={`https://colab.research.google.com/github/${SITE_REPO}/blob/main/${notebookPath}`}
            rel="noreferrer"
          >
            Open in Colab
          </a>
        </div>
      )}
      <div class="prose">
        <Content />
      </div>
      <div class="footer-row">
        <a class="back" href="/tutorials/">← All tutorials</a>
        <a class="edit-link" href={editUrl(SITE_REPO, entry.filePath)}
          >Edit this page on GitHub</a
        >
      </div>
    </article>

    <aside data-pagefind-ignore>
      <ArticleToc headings={headings} />
    </aside>
  </div>
</Layout>

<style>
.narrow-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 200px;
  gap: 56px;
  max-width: 1140px;
  padding-top: 36px;
}

.head {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
  margin-top: 22px;
}

.meta {
  font-size: 11.5px;
  color: var(--text-mute);
}

h1 {
  margin-top: 12px;
  font-size: clamp(28px, 3vw, 38px);
}

.uses {
  margin-top: 10px;
  font-size: 12px;
  color: var(--text-mute);
}

.sub {
  margin-top: 12px;
  font-family: var(--serif);
  font-size: 16.5px;
  font-weight: 300;
  color: var(--text-soft);
}

.nb-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 20px;
}

.nb-actions .btn {
  padding: 6px 14px;
  font-size: 12.5px;
}

.prose {
  margin-top: 28px;
}

@media (width <= 960px) {
  .narrow-grid {
    grid-template-columns: minmax(0, 1fr);
  }

  aside {
    display: none;
  }
}
</style>
