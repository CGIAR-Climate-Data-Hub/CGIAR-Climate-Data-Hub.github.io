---
import { getCollection, render } from "astro:content";
import ArticleToc from "@/components/ArticleToc.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import JsonLd from "@/components/JsonLd.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE_NAME } from "@/site.config";

export async function getStaticPaths() {
  const entries = await getCollection("tutorials");
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// "20 min" / "2 hrs" → ISO 8601 duration for schema.org timeRequired
const match = entry.data.time.match(/(\d+)\s*(min|hr|hour)/);
const timeRequired =
  match && (match[2] === "min" ? `PT${match[1]}M` : `PT${match[1]}H`);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["TechArticle", "LearningResource"],
  headline: entry.data.title,
  description: entry.data.description,
  url: new URL(`/tutorials/${entry.id}`, Astro.site).href,
  educationalLevel: entry.data.level,
  ...(timeRequired && { timeRequired }),
  dateModified: entry.data.updated.toISOString().slice(0, 10),
  author: { "@type": "Organization", name: `CGIAR ${SITE_NAME}` },
  isPartOf: { "@type": "WebSite", "@id": `${Astro.site}#website` },
};
---

<Layout
  description={entry.data.description}
  title={`${entry.data.title} — ${SITE_NAME}`}
>
  <JsonLd data={jsonLd} slot="head" />

  <div class="container narrow-grid">
    <article>
      <Breadcrumbs
        items={[{ label: "Hub", href: "/" }, { label: "Tutorials", href: "/tutorials" }, { label: entry.data.title }]}
      />
      <div class="head">
        <span
          class:list={["pill", "dot", entry.data.level === "Beginner" ? "spatial" : "warn"]}
        >
          {entry.data.level}
        </span>
        <span class="pill">{entry.data.topic}</span>
        <span class="mono meta">{entry.data.time} · {entry.data.format}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="sub">{entry.data.description}</p>
      <div class="prose">
        <Content />
      </div>
    </article>

    <aside data-pagefind-ignore>
      <ArticleToc headings={headings} />
    </aside>
  </div>
</Layout>

<style>
.narrow-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 200px;
  gap: 56px;
  max-width: 1140px;
  padding-top: 36px;
}

.head {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
  margin-top: 22px;
}

.meta {
  font-size: 11.5px;
  color: var(--text-mute);
}

h1 {
  margin-top: 12px;
  font-size: clamp(28px, 3vw, 38px);
}

.sub {
  margin-top: 12px;
  font-family: var(--serif);
  font-size: 16.5px;
  font-weight: 300;
  color: var(--text-soft);
}

.prose {
  margin-top: 28px;
}

@media (width <= 960px) {
  .narrow-grid {
    grid-template-columns: minmax(0, 1fr);
  }

  aside {
    display: none;
  }
}
</style>
