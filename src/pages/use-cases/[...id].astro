---
import { getCollection, render } from "astro:content";
import ArticleToc from "@/components/ArticleToc.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import JsonLd from "@/components/JsonLd.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE_NAME } from "@/site.config";

export async function getStaticPaths() {
  const entries = await getCollection("useCases");
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const date = entry.data.date.toISOString().slice(0, 10);

// Resolve dataset ids to titles for the "data used" links
const datasets = (
  await getCollection("catalog", (c) => entry.data.datasets.includes(c.data.id))
).map((c) => ({ href: `/catalog/${c.data.id}`, title: c.data.title }));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: date,
  url: new URL(`/use-cases/${entry.id}`, Astro.site).href,
  author: { "@type": "Organization", name: `CGIAR ${SITE_NAME}` },
  about: entry.data.sector,
  contentLocation: { "@type": "Place", name: entry.data.country },
  isPartOf: { "@type": "WebSite", "@id": `${Astro.site}#website` },
};
---

<Layout
  description={entry.data.description}
  title={`${entry.data.title} — ${SITE_NAME}`}
>
  <JsonLd data={jsonLd} slot="head" />

  <div class="container narrow-grid">
    <article>
      <Breadcrumbs
        items={[{ label: "Hub", href: "/" }, { label: "In use", href: "/use-cases" }, { label: entry.data.title }]}
      />
      <div class="head">
        <span
          class:list={["pill", "dot", entry.data.kind === "Impact" ? "spatial" : "warn"]}
        >
          {entry.data.kind}
        </span>
        <span class="mono meta">{entry.data.country} · {date}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="sub">{entry.data.description}</p>
      <div class="label partner">{entry.data.partner}</div>

      {entry.data.impact.length > 0 && (
          <aside aria-label="Key takeaways" class="takeaways">
            <div class="label">Key takeaways</div>
            <ul>
              {entry.data.impact.map((line) => (
                <li>{line}</li>
              ))}
            </ul>
          </aside>
        )}

      <div class="prose">
        <Content />
      </div>

      {datasets.length > 0 && (
          <div class="data-used">
            <div class="label">Data used</div>
            {datasets.map((d) => (
              <a href={d.href}>{d.title} →</a>
            ))}
          </div>
        )}
    </article>

    <aside data-pagefind-ignore>
      <ArticleToc headings={headings} />
    </aside>
  </div>
</Layout>

<style>
.narrow-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 200px;
  gap: 56px;
  max-width: 1140px;
  padding-top: 36px;
}

.head {
  display: flex;
  gap: 12px;
  align-items: center;
  margin-top: 22px;
}

.meta {
  font-size: 11.5px;
  color: var(--text-mute);
}

h1 {
  margin-top: 12px;
  font-size: clamp(28px, 3.2vw, 42px);
}

.sub {
  max-width: 660px;
  margin-top: 14px;
  font-family: var(--serif);
  font-size: 17px;
  font-weight: 300;
  line-height: 1.6;
  color: var(--text-soft);
}

.partner {
  margin-top: 14px;
  color: var(--text-mute);
}

.takeaways {
  padding: 18px 22px;
  margin-top: 28px;
  background: var(--cdh-blue-50);
  border-left: 3px solid var(--cdh-blue-700);
  border-radius: 0 8px 8px 0;
}

.takeaways .label {
  color: var(--cdh-blue-800);
}

.takeaways ul {
  padding-left: 18px;
  margin: 10px 0 0;
}

.takeaways li {
  padding: 3px 0;
  font-size: 14.5px;
  color: var(--cdh-blue-950);
}

.prose {
  margin-top: 28px;
}

.data-used {
  padding-top: 20px;
  margin-top: 24px;
  border-top: 1px solid var(--border);
}

.data-used a {
  display: block;
  margin-top: 8px;
  font-size: 14px;
  font-weight: 600;
}

@media (width <= 960px) {
  .narrow-grid {
    grid-template-columns: minmax(0, 1fr);
  }

  .narrow-grid > aside {
    display: none;
  }
}
</style>
