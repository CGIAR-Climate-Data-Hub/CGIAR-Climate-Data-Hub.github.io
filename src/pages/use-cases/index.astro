---
import { getCollection } from "astro:content";
import PageHead from "@/components/PageHead.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE_NAME } from "@/site.config";

const all = (await getCollection("useCases")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const featured = all.find((uc) => uc.data.featured) ?? all[0];
const rest = all.filter((uc) => uc !== featured);
const description =
  "Where Climate Data Hub data and standards are working in the field — impact stories and adoption.";

const monthYear = (d: Date) =>
  d.toLocaleDateString("en-GB", { month: "long", year: "numeric" });
---

<Layout description={description} title={`In use — ${SITE_NAME}`}>
  <PageHead
    breadcrumb={[{ label: "Hub", href: "/" }, { label: "In use" }]}
    kicker="In use"
    sub="Hub data, tools, and standards at work — in country planning, investment cases, and partner systems."
    title="Evidence in the field"
  />

  <div class="container">
    <a class="featured" href={`/use-cases/${featured.id}`}>
      <div class="featured-body">
        <span class="pills">
          <span class="pill dark dot">{featured.data.kind}</span>
          <span class="mono featured-meta"
            >{featured.data.country}
            · {monthYear(featured.data.date)}</span
          >
        </span>
        <span class="featured-title">{featured.data.title}</span>
        <span class="featured-summary">{featured.data.description}</span>
        <span class="featured-partner label">{featured.data.partner}</span>
      </div>
      {featured.data.impact.length > 0 && (
          <ul class="featured-impact">
            {featured.data.impact.map((line) => (
              <li>{line}</li>
            ))}
          </ul>
        )}
    </a>

    <div class="rows">
      {rest.map((uc) => (
          <a class="row" href={`/use-cases/${uc.id}`}>
            <span class:list={["pill", "dot", uc.data.kind === "Impact" ? "spatial" : "warn"]}>{uc.data.kind}</span>
            <span class="row-text">
              <span class="row-title">{uc.data.title}</span>
              <span class="row-summary">{uc.data.description}</span>
              <span class="label row-partner">{uc.data.partner}</span>
            </span>
            <span class="mono row-meta">
              {uc.data.country} · {monthYear(uc.data.date)}
            </span>
          </a>
        ))}
    </div>
  </div>
</Layout>

<style>
.featured {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 48px;
  padding: 44px 48px;
  margin-top: 40px;
  color: #fff;
  background: var(--cdh-blue-950);
  border-radius: 16px;
  transition:
    box-shadow 0.16s,
    transform 0.16s;
}

.featured:hover {
  text-decoration: none;
  box-shadow: 0 16px 44px rgb(12 44 87 / 28%);
  transform: translateY(-2px);
}

.pills {
  display: flex;
  gap: 12px;
  align-items: center;
}

.featured-meta {
  font-size: 11.5px;
  color: rgb(255 255 255 / 55%);
}

.featured-title {
  display: block;
  margin-top: 16px;
  font-family: var(--serif);
  font-size: clamp(24px, 2.6vw, 32px);
  font-weight: 600;
  line-height: 1.18;
  letter-spacing: -0.01em;
}

.featured-summary {
  display: block;
  max-width: 560px;
  margin-top: 12px;
  font-size: 15px;
  line-height: 1.6;
  color: rgb(255 255 255 / 76%);
}

.featured-partner {
  display: block;
  margin-top: 18px;
  color: var(--cdh-blue-300);
}

.featured-impact {
  align-self: center;
  padding: 0 0 0 24px;
  margin: 0;
  list-style: none;
  border-left: 1px solid rgb(255 255 255 / 16%);
}

.featured-impact li {
  padding: 10px 0;
  font-family: var(--serif);
  font-size: 16px;
  font-weight: 300;
  line-height: 1.45;
  color: rgb(255 255 255 / 88%);
  border-top: 1px solid rgb(255 255 255 / 12%);
}

.featured-impact li:first-child {
  border-top: 0;
}

.rows {
  margin-top: 32px;
  border-top: 1px solid var(--border);
}

.row {
  display: flex;
  flex-wrap: wrap;
  gap: 12px 24px;
  align-items: baseline;
  padding: 22px 6px;
  color: var(--text);
  border-bottom: 1px solid var(--border);
  transition: background 0.12s;
}

.row:hover {
  text-decoration: none;
  background: var(--surface);
}

.row-text {
  flex: 1 1 480px;
  min-width: 0;
}

.row-title {
  display: block;
  font-family: var(--serif);
  font-size: 20px;
  font-weight: 500;
  color: var(--cdh-blue-950);
}

.row-summary {
  display: block;
  max-width: 640px;
  margin-top: 4px;
  font-size: 14px;
  line-height: 1.55;
  color: var(--text-soft);
}

.row-partner {
  display: block;
  margin-top: 8px;
  font-size: 10px;
  color: var(--text-mute);
}

.row-meta {
  font-size: 11.5px;
  color: var(--text-mute);
}

@media (width <= 860px) {
  .featured {
    grid-template-columns: 1fr;
    gap: 24px;
    padding: 32px 28px;
  }

  .featured-impact {
    padding-left: 0;
    border-left: 0;
  }
}
</style>
