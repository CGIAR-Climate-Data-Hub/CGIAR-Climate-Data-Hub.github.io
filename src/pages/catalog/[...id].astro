      <div class="footer-row">
        <a class="back" href="/catalog/">← Back to the catalog</a>
      </div>
    </article>

    <aside>
      <div class="rail-box">
        <h4 class="label">Quick facts</h4>
        <dl class="kv">
          {coverage && (
            <>
