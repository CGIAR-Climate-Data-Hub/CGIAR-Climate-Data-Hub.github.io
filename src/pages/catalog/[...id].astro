---
import { Code } from "astro:components";
import { getCollection } from "astro:content";
import { satteri } from "@astrojs/markdown-satteri";
import BboxMap from "@/components/BboxMap.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import CopyButton from "@/components/CopyButton.astro";
import JsonLd from "@/components/JsonLd.astro";
import SnippetTabs from "@/components/SnippetTabs.astro";
import Layout from "@/layouts/Layout.astro";
import {
  bibtex,
  citationFormats,
  citationText,
  datasetJsonLd,
  geoLabel,
  hubRecordId,
  humanize,
  licenseUrl,
  normalizeBboxes,
  stacCollectionUrl,
  temporalText,
  versionChain,
} from "@/lib/catalog";
import { codeHeader, shikiConfig } from "@/lib/code-block";
import { allTutorials } from "@/lib/collections";
import {
  assetExample,
  formatBestFor,
  formatLabel,
  quickstarts,
} from "@/lib/snippets";
import { commodity } from "@/lib/vocab";
import { CATALOG_REPO, SITE_NAME } from "@/site.config";

export async function getStaticPaths() {
  const entries = await getCollection("catalog");
  // Record descriptions may carry markdown; render like any other content
  const markdown = await satteri().createRenderer({ shikiConfig });
  // No series/redirect routes: per the standard (§4.7) the unversioned id is
  // always the current release, updated in place; snapshots are their own
  // records marked deprecated.
  return Promise.all(
    entries.map(async (entry) => ({
      params: { id: entry.data.id },
      props: {
        entry,
        descriptionHtml: (await markdown.render(entry.data.description)).code,
      },
    })),
  );
}

const { entry, descriptionHtml } = Astro.props;
const d = entry.data;

const catalog = await getCollection("catalog");
// Newest-first version chain; the head is the current release
const chain = versionChain(d.id, catalog);
const current = chain[0]?.data.id !== d.id ? chain[0] : undefined;

// Provenance cross-links: derived_from urls that resolve to Hub records
// render as internal links, and records derived from this one list in the
// rail. The links carry the graph; there is no drawn DAG.
const hubSource = (url: string) => {
  const rec = catalog.find((e) => e.data.id === hubRecordId(url));
  return rec && { href: `/catalog/${rec.data.id}/`, title: rec.data.title };
};
const derivatives = catalog
  .filter(
    (e) =>
      !e.data.deprecated
      && e.data.processing.some((s) =>
        s.derived_from.some((src) => hubRecordId(src.url) === d.id),
      ),
  )
  .map((e) => ({ href: `/catalog/${e.data.id}/`, title: e.data.title }));

const bboxes = normalizeBboxes(d.spatial?.bbox);
const coverage = d.spatial?.geography.map(geoLabel).join(", ");
const resolution = d.spatial?.resolution
  .map((r) => r.label)
  .filter(Boolean)
  .join(" · ");
const temporal = temporalText(d.temporal);
// Time is an implicit axis: a temporal resolution means a time dimension,
// which records never declare explicitly — the site appends it here.
const timeDimension = d.temporal?.resolution && {
  name: "time",
  type: "temporal",
  description: d.temporal.resolution.note,
  values:
    d.temporal.resolution.values.length > 0
      ? d.temporal.resolution.values
      : [temporal?.main ?? ""].filter(Boolean),
};
const dimensions = timeDimension
  ? [...d.dimensions, timeDimension]
  : d.dimensions;
// The header's source line: the licensor (a required role in the standard)
const source = d.contact.find((c) =>
  c.roles.includes("licensor"),
)?.organization;
// Contact order: custodians (hub-side stewards), then licensors, then the rest
const roleRank = (c: (typeof d.contact)[number]) =>
  c.roles.includes("custodian") ? 2 : c.roles.includes("licensor") ? 1 : 0;
const contacts = [...d.contact]
  .sort((a, b) => roleRank(b) - roleRank(a))
  .map((c) => ({
    ...c,
    otherRoles: c.roles.filter((r) => r !== "custodian" && r !== "licensor"),
  }));
const recordUrl = new URL(`/catalog/${d.id}/`, Astro.site).href;
const restricted = Boolean(d.access && d.access !== "open");
const crsHref =
  d.spatial?.crs && /^EPSG:\d+$/.test(d.spatial.crs)
    ? `https://epsg.io/${d.spatial.crs.split(":")[1]}`
    : undefined;
const hasSchema = dimensions.length + d.variables.length > 0;
const hasTemplated = d.data.some((a) => a.href_template);
const stacUrl = stacCollectionUrl(d.id);
// Record metadata lives in the catalog repo, so source + issue links point
// there. Flat strings on purpose: Biome's Astro frontmatter parser trips on
// template literals nested two deep.
const sourceUrl = entry.filePath
  ? `https://github.com/${CATALOG_REPO}/blob/main/${entry.filePath}`
  : undefined;
const reportBody = [
  `Record page: ${recordUrl}`,
  sourceUrl ? `Source: ${sourceUrl}` : "",
  "",
  "**What's wrong?**",
  "",
].join("\n");
const reportParams = new URLSearchParams({
  title: `[record] ${d.id}: `,
  body: reportBody,
});
const reportUrl = `https://github.com/${CATALOG_REPO}/issues/new?${reportParams}`;
const citation = citationText(d, recordUrl);
const citeFormats = citationFormats(d, recordUrl);
const licenseHref = licenseUrl(d.license);
const bibtexStr = bibtex(d, recordUrl);

// Build-time cross-links: stories and tutorials citing this dataset id
const seenIn = (
  await getCollection("useCases", (uc) => uc.data.datasets.includes(d.id))
).map((uc) => ({
  href: `/use-cases/${uc.id}/`,
  title: uc.data.title,
  partner: uc.data.partner,
}));
const tutorialLinks = (await allTutorials())
  .filter((t) => t.data.datasets.includes(d.id))
  .map((t) => ({
    href: `/tutorials/${t.id}/`,
    title: t.data.title,
    meta: `${t.data.level} · ${t.data.time}`,
  }));

// Long URLs wrap at path boundaries, not mid-token: each segment gets a
// <wbr> break hint (see also the picker's replaceChildren in the script)
const urlParts = (url: string) => url.split(/(?<=\/)/);

// Example code, from the template files in src/snippets (see lib/snippets).
// The quick start stacks one short block per format; each asset card in
// Access & use carries its own worked example (spatial clip / point sample).
const quickstart = {
  python: quickstarts(d, "py").join("\n\n"),
  r: quickstarts(d, "R").join("\n\n"),
};

// Everything the asset card renders, derived once per asset:
// - tplFields: one select per template placeholder, options from the cube's
//   dimensions (and variable names); undefined unless every one resolves
// - tplFile/tplUrl: the picker's prerendered default (first value per field)
// - primary: the spotlighted access route (HTTPS when available); others
//   fills the disclosure — everything on templated assets, where the picker
//   stands in for the access panel and no root URL shows above
// - download: only where one click yields one file — an http(s) URL to a
//   single object, never templated collections, Zarr stores, or prefixes
const assets = [...d.data, ...d.additional_assets].map((asset) => {
  const httpUrl = asset.locations.find((l) => l.url.startsWith("http"))?.url;
  const primary =
    asset.locations.find((l) => l.url === httpUrl) ?? asset.locations[0];

  let tplFields: { name: string; values: string[] }[] | undefined;
  let tplFile: string | undefined;
  if (asset.href_template) {
    const fields = [
      ...new Set(
        [...asset.href_template.matchAll(/\{(\w+)\}/g)].map((m) => m[1]),
      ),
    ].map((name) => ({
      name,
      values:
        dimensions.find((dim) => dim.name === name)?.values
        ?? (name === "variable" ? d.variables.map((v) => v.name) : []),
    }));
    if (fields.every((f) => f.values.length > 0)) {
      tplFields = fields;
      tplFile = asset.href_template;
      for (const f of fields)
        tplFile = tplFile.replaceAll(`{${f.name}}`, f.values[0]);
    }
  }

  const lastSegment = httpUrl?.split("/").pop() ?? "";
  return {
    asset,
    example: assetExample(d, asset),
    bestFor: formatBestFor(asset.media_type),
    primary,
    others: asset.href_template
      ? asset.locations
      : asset.locations.filter((l) => l !== primary),
    tplFields,
    tplFile,
    tplUrl: tplFile && httpUrl ? httpUrl + tplFile : undefined,
    download:
      !asset.href_template
      && httpUrl
      && !httpUrl.endsWith("/")
      && lastSegment.includes(".")
      && !lastSegment.endsWith(".zarr")
        ? httpUrl
        : undefined,
  };
});
// The standard separates the distributions from supporting material
const assetGroups = [
  { title: "Data", items: assets.slice(0, d.data.length) },
  { title: "Additional assets", items: assets.slice(d.data.length) },
].filter((g) => g.items.length > 0);

const SECTIONS = [
  ["overview", "Overview"],
  hasSchema && ["schema", "Schema"],
  (d.climate || d.spatial || d.temporal) && ["technical", "Technical metadata"],
  d.data.length > 0 && ["access", "Access & use"],
  d.processing.length > 0 && ["provenance", "Provenance"],
  (citation || d.contact.length > 0) && [
    "citation",
    citation && d.contact.length > 0
      ? "Citation & contacts"
      : citation
        ? "Citation"
        : "Contacts",
  ],
].filter(Boolean) as [string, string][];

const jsonLd = datasetJsonLd(
  d,
  recordUrl,
  new URL("/catalog/", Astro.site).href,
);
---

<Layout
  description={d.description.slice(0, 160)}
  title={`${d.title} — ${SITE_NAME}`}
>
  <JsonLd data={jsonLd} slot="head" />

  <section class="header">
    <div class="container">
      <Breadcrumbs
        items={[{ label: "Hub", href: "/" }, { label: "Catalog", href: "/catalog/" }, { label: d.title }]}
      />
      {d.deprecated && (
        <div class="deprecated-note">
          This is a frozen snapshot of an older release{d.version ? ` (${d.version})` : ""}.
          {current && (
            <>
              {" "}
              <a href={`/catalog/${current.data.id}/`}>
                Go to the current version
                {current.data.version ? ` (${current.data.version})` : ""} →
              </a>
            </>
          )}
        </div>
      )}
      <div class="header-grid">
        <div>
          <h1>{d.title}</h1>
          {source && <p class="source">{source}</p>}
          {d.series && (
            <p class="series-line">
              Part of:{" "}
              <a href={`/catalog/?series=${encodeURIComponent(d.series.name)}`}>
                {d.series.name}
              </a>
            </p>
          )}

          {(d.version || restricted) && (
            <div class="version-row">
              {d.version && <span class="label">Version</span>}
              {d.version && chain.length > 1 ? (
                <details class="drop-menu version-menu">
                  <summary class="btn btn-ghost">
                    {d.version}
                    {!current && <span class="latest">LATEST</span>}
                    <svg
                      aria-hidden="true"
                      fill="none"
                      height="10"
                      stroke="currentColor"
                      stroke-width="2.4"
                      viewBox="0 0 24 24"
                      width="10"
                    >
                      <path d="M6 9l6 6 6-6" />
                    </svg>
                  </summary>
                  <div class="menu-list">
                    {chain.map((v, i) => (
                      <a
                        aria-current={v.data.id === d.id ? "page" : undefined}
                        href={`/catalog/${v.data.id}/`}
                      >
                        {v.data.version ?? v.data.id}
                        {i === 0 && <span class="latest">LATEST</span>}
                      </a>
                    ))}
                  </div>
                </details>
              ) : (
                d.version && <span class="version-single">{d.version}</span>
              )}
              {restricted && (
                <span class="mono access-flag">
                  {humanize(d.access ?? "")} access
                </span>
              )}
            </div>
          )}

          <div class="mono meta-row">
            <span class="fact">
              <span class="fact-label">license</span>
              {licenseHref ? (
                <a href={licenseHref} rel="noreferrer">{d.license}</a>
              ) : (
                d.license
              )}
            </span>
            {d.doi && (
              <span class="fact">
                <span class="fact-label">doi</span>
                <a href={`https://doi.org/${d.doi}`}>{d.doi}</a>
              </span>
            )}
            {d.updated && (
              <span class="fact">
                <span class="fact-label">updated</span>
                {d.updated}
              </span>
            )}
          </div>

          <div class="ctas">
            <a class="btn btn-primary" href="#access">
              {restricted ? "Request access" : "Access the data"}
            </a>
            <details class="drop-menu meta-menu">
              <summary class="btn btn-ghost">
                Metadata
                <svg
                  aria-hidden="true"
                  fill="none"
                  height="10"
                  stroke="currentColor"
                  stroke-width="2.4"
                  viewBox="0 0 24 24"
                  width="10"
                >
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </summary>
              <div class="menu-list">
                <a href={`/catalog/${d.id}.json`}>Raw record (JSON)</a>
                {hasTemplated && (
                  <a href={stacUrl} rel="noreferrer">
                    STAC Collection ↗
                  </a>
                )}
                {entry.filePath && (
                  <a
                    class="menu-split"
                    href={`https://github.com/${CATALOG_REPO}/edit/main/${entry.filePath}`}
                    >Suggest an edit ↗</a
                  >
                )}
                <a
                  class:list={[{ "menu-split": !entry.filePath }]}
                  href={reportUrl}
                  rel="noreferrer"
                >
                  Report a problem ↗
                </a>
              </div>
            </details>
          </div>
        </div>

        <div>
          <BboxMap bboxes={bboxes} label={coverage} />
        </div>
      </div>
    </div>
  </section>

  <nav aria-label="Sections" class="section-nav">
    <div class="container">
      {SECTIONS.map(([id, label]) => <a href={`#${id}`}>{label}</a>)}
    </div>
  </nav>

  <div class="container body">
    <article>
      <section id="overview">
        <div class="prose" set:html={descriptionHtml} />

        {d.keywords.length > 0 && (
            <div class="keywords">
              {d.keywords.map((k) =>
                typeof k === "string" ? (
                  <a class="mono keyword" href={`/catalog/?q=${encodeURIComponent(k)}`}>
                    #{k}
                  </a>
                ) : (
                  <a class="mono keyword ontology" href={k.uri ?? k.scheme} rel="noreferrer" title={`${k.scheme ?? "ontology"} concept`}>
                    {k.term} ↗
                  </a>
                ),
              )}
            </div>
          )}

        {d.note && (
            <div class="note">
              <h3>Important note</h3>
              <p>{d.note}</p>
            </div>
          )}

        {(quickstart.python || quickstart.r) && (
            <div>
              <h3>Quick start</h3>
              <SnippetTabs python={quickstart.python} r={quickstart.r} />
              <p class="digest">
                <a href="#access">Full access details and endpoints</a>
              </p>
            </div>
          )}

        {d.cdh && d.cdh.use_cases.length > 0 && (
            <div>
              <h3>Good for</h3>
              <ul>
                {d.cdh.use_cases.map((u) => (
                  <li>{humanize(u)}</li>
                ))}
              </ul>
            </div>
          )}

        {d.cdh && d.cdh.not_recommended_for.length > 0 && (
            <div>
              <h3>Not recommended for</h3>
              <div class="warn-cards">
                {d.cdh.not_recommended_for.map((n) => (
                  <div class="warn-card">
                    <b>{humanize(n.use)}</b>
                    {n.reason && (
                      <p>
                        <b>Why:</b> {humanize(n.reason)}
                      </p>
                    )}
                    {n.use_instead && (
                      <p class="instead">
                        <b>Use instead:</b> {humanize(n.use_instead)}
                      </p>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

        {d.commodities.length > 0 && (
            <div>
              <h3>Commodities</h3>
              <div class="chips">
                {d.commodities.map((id) => {
                  const c = commodity(id);
                  return c?.uri ? (
                    <a class="chip" href={c.uri} rel="noreferrer" title={`AGROVOC ${c.code}`}>
                      {c.label} ↗
                    </a>
                  ) : (
                    <span class="chip">{c?.label ?? humanize(id)}</span>
                  );
                })}
              </div>
            </div>
          )}
      </section>

      {hasSchema && (
          <section id="schema">
            {d.variables.length > 0 && (
              <div>
                <h3>Variables</h3>
                <div class="table-wrap">
                  <table>
                    <thead>
                      <tr>
                        <th>Variable</th>
                        <th>Type</th>
                        <th>Unit</th>
                        <th>Description</th>
                      </tr>
                    </thead>
                    <tbody>
                      {d.variables.map((v) => {
                        const classValues = d.classes.find(
                          (c) => c.variable === v.name,
                        )?.values;
                        return (
                          <tr>
                            <td class="mono var-name">{v.name}</td>
                            <td class="mono">{v.data_type ?? "—"}</td>
                            <td class="mono">{v.unit ?? "—"}</td>
                            <td>
                              {v.description ?? "—"}
                              {v.note && <div class="var-note">{v.note}</div>}
                              {classValues && classValues.length > 0 && (
                                <dl class="class-list">
                                  {classValues.map((cv) => (
                                    <>
                                      <dt class="mono">{cv.value}</dt>
                                      <dd>
                                        {cv.label}
                                        {cv.description && (
                                          <span class="class-desc">
                                            {" "}
                                            — {cv.description}
                                          </span>
                                        )}
                                      </dd>
                                    </>
                                  ))}
                                </dl>
                              )}
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {dimensions.length > 0 && (
              <div>
                <h3>Dimensions</h3>
                <p class="section-sub">Axes of the cube — spatial, temporal, and domain axes.</p>
                <div class="dim-cards">
                  {dimensions.map((dim) => (
                    <div class="dim-card">
                      <div class="dim-head">
                        <span class="mono dim-name">{dim.name}</span>
                        {dim.type && <span class="label">{dim.type}</span>}
                      </div>
                      {dim.description && <p>{dim.description}</p>}
                      {dim.values.length > 0 && (
                        <div class="chips">
                          {dim.values.map((v) => (
                            <span class="chip mono">{v}</span>
                          ))}
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </section>
        )}

      {d.data.length > 0 && (
          <section id="access">
            <h3>Access &amp; use</h3>
            <p class="section-sub">
              Cloud-optimised distributions — read just the window you need directly from object
              storage.
            </p>
            {d.access_note && (
              <div class="note">
                <h3>Access conditions</h3>
                <p>{d.access_note}</p>
              </div>
            )}
            {hasTemplated && (
              <p class="digest">
                Machine-readable file index:{" "}
                <a href={stacUrl} rel="noreferrer">STAC Collection</a>
              </p>
            )}

            {assetGroups.map((group) => (
            <div>
              <h4 class="tech-title">{group.title}</h4>
            <div class="assets">
              {group.items.map(({ asset, example, bestFor, primary, others, tplFields, tplFile, tplUrl, download }) => (
                <div class="asset">
                  <div class="asset-head">
                    <span class="mono asset-name">{asset.name}</span>
                    {asset.file_size && <span class="mono asset-size">{asset.file_size}</span>}
                    {download && (
                      <a class="btn btn-ghost dl" download href={download}>
                        Download
                      </a>
                    )}
                  </div>
                  {asset.description && <p class="asset-desc">{asset.description}</p>}
                  {asset.media_type && (
                    <p class="asset-fact">
                      <b>Format:</b> {formatLabel(asset.media_type)}
                      {bestFor && (
                        <span class="best-for"> — best for {bestFor}</span>
                      )}
                    </p>
                  )}
                  {asset.nodata !== undefined && (
                    <p class="asset-fact">
                      <b>No Data:</b> <span class="mono">{asset.nodata}</span>
                    </p>
                  )}
                  {tplUrl && (
                      <div
                        class="tpl-picker"
                        data-file={tplFile}
                        data-root={primary.url}
                        data-template={asset.href_template}
                      >
                        <p class="label tpl-title">Access a specific file</p>
                        <div class="tpl-fields">
                          {(tplFields ?? []).map((f) => (
                            <label class="tpl-field">
                              <span class="label">{humanize(f.name)}</span>
                              <select data-tpl-dim={f.name}>
                                {f.values.map((v) => <option>{v}</option>)}
                              </select>
                            </label>
                          ))}
                        </div>
                        <p class="asset-fact tpl-selected">
                          <span class="mono selected-url" data-tpl-url>{tplUrl}</span>
                          <CopyButton
                            copy={tplUrl}
                            label="Copy selected file URL"
                          />
                          <a class="btn btn-ghost dl" download href={tplUrl}>
                            Download
                          </a>
                        </p>
                      </div>
                    )}
                  {!asset.href_template && primary && (
                    <div class="access-panel">
                      <p class="label tpl-title">Access the data</p>
                      <p class="asset-fact access-row">
                        <span class="mono url">
                          {urlParts(primary.url).map((part) => (
                            <>
                              {part}
                              <wbr />
                            </>
                          ))}
                        </span>
                        <CopyButton copy={primary.url} label="Copy URL" />
                      </p>
                    </div>
                  )}
                  {others.length > 0 && (
                    <details class="alt-access">
                      <summary>Other access methods</summary>
                      {asset.href_template && (
                        <p class="asset-fact">
                          <b>File pattern:</b>{" "}
                          <span class="mono">{asset.href_template}</span>
                        </p>
                      )}
                      {others.map((loc) => (
                        <div class="endpoint">
                          <span class="proto">
                            {loc.title ?? "URL"}
                            {asset.href_template ? " directory" : ""}:
                          </span>
                          <span class="mono url">
                            {urlParts(loc.url).map((part) => (
                              <>
                                {part}
                                <wbr />
                              </>
                            ))}
                          </span>
                          <CopyButton copy={loc.url} label="Copy URL" />
                        </div>
                      ))}
                    </details>
                  )}
                  {example && (
                    <div class="example-row">
                      <button class="example-btn" data-example-open type="button">
                        <span aria-hidden="true" class="mono">&lt;/&gt;</span>
                        View usage examples
                      </button>
                      <dialog class="example-modal">
                        <div class="example-head">
                          <h4>
                            <span class="mono">{asset.name}</span> — usage
                            examples
                          </h4>
                          <button
                            aria-label="Close"
                            class="example-close"
                            data-example-close
                            type="button"
                          >
                            ×
                          </button>
                        </div>
                        <SnippetTabs python={example.python} r={example.r} />
                      </dialog>
                    </div>
                  )}
                </div>
              ))}
            </div>
            </div>
            ))}
          </section>
        )}

      {(d.climate || d.spatial || d.temporal) && (
          <section id="technical">
            <h3>Technical metadata</h3>
            <p class="section-sub">
              The full spatial, temporal, and modelling detail behind the
              summaries elsewhere on this page.
            </p>

            {d.spatial && (
              <div>
