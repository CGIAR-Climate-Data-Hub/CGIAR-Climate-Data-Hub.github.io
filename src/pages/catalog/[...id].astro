                          .filter(Boolean)
                          .join(" · ")}
                      </dd>
                    </>
                  )}
              </dl>
            </div>
            )}

            <div>
              <h4 class="tech-title">Record</h4>
              <dl class="kv">
                <dt>Resource type</dt>
                <dd>{d.resource_type}</dd>
                {d.created && (
                  <>
