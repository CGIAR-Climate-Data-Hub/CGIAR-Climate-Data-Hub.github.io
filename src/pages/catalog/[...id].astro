---
import { Code } from "astro:components";
import { getCollection } from "astro:content";
import { satteri } from "@astrojs/markdown-satteri";
import BboxMap from "@/components/BboxMap.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import JsonLd from "@/components/JsonLd.astro";
import SnippetTabs from "@/components/SnippetTabs.astro";
import Layout from "@/layouts/Layout.astro";
import {
  bibtex,
  citationText,
  datasetJsonLd,
  geoLabel,
  humanize,
  licenseUrl,
  normalizeBboxes,
  stacCollectionUrl,
  temporalText,
} from "@/lib/catalog";
import { allTutorials } from "@/lib/collections";
import { assetExample, formatLabel, quickstarts } from "@/lib/snippets";
import { commodity } from "@/lib/vocab";
import { GITHUB_URL, SITE_NAME } from "@/site.config";

export async function getStaticPaths() {
  const entries = await getCollection("catalog");
  // Record descriptions may carry markdown; render like any other content
  const markdown = await satteri().createRenderer({});
  // Records sharing a catalog folder are versions of the same dataset
  const familyOf = (id: string) => id.split("/")[0];
  return Promise.all(
    entries.map(async (entry) => ({
      params: { id: entry.data.id },
      props: {
        entry,
        descriptionHtml: (await markdown.render(entry.data.description)).code,
        versions: entries
          .filter((e) => familyOf(e.id) === familyOf(entry.id))
          .map((e) => ({
            id: e.data.id,
            version: e.data.version,
            updated: e.data.updated ?? e.data.created ?? "",
          }))
          .sort((a, b) => b.updated.localeCompare(a.updated)),
      },
    })),
  );
}

const { entry, versions, descriptionHtml } = Astro.props;
const d = entry.data;

const bboxes = normalizeBboxes(d.spatial?.bbox);
const coverage = d.spatial?.geography.map(geoLabel).join(", ");
const resolution = d.spatial?.resolution
  .map((r) => r.label)
  .filter(Boolean)
  .join(" · ");
const temporal = temporalText(d.temporal);
// The header's source line: the licensor (a required role in the standard)
const source = d.contact.find((c) =>
  c.roles.includes("licensor"),
)?.organization;
// Contact order: custodians (hub-side stewards), then licensors, then the rest
const roleRank = (c: (typeof d.contact)[number]) =>
  c.roles.includes("custodian") ? 2 : c.roles.includes("licensor") ? 1 : 0;
const contacts = [...d.contact].sort((a, b) => roleRank(b) - roleRank(a));
const recordUrl = new URL(`/catalog/${d.id}/`, Astro.site).href;
const citation = citationText(d, recordUrl);
const licenseHref = licenseUrl(d.license);
const bibtexStr = bibtex(d, recordUrl);

// Build-time cross-links: stories and tutorials citing this dataset id
const seenIn = (
  await getCollection("useCases", (uc) => uc.data.datasets.includes(d.id))
).map((uc) => ({
  href: `/use-cases/${uc.id}/`,
  title: uc.data.title,
  partner: uc.data.partner,
}));
const tutorialLinks = (await allTutorials())
  .filter((t) => t.data.datasets.includes(d.id))
  .map((t) => ({
    href: `/tutorials/${t.id}/`,
    title: t.data.title,
    meta: `${t.data.level} · ${t.data.time}`,
  }));

// Example code, from the template files in src/snippets (see lib/snippets).
// The quick start stacks one short block per format; each asset card in
// Access & use carries its own worked example (spatial clip / point sample).
const quickstart = {
  python: quickstarts(d, "py").join("\n\n"),
  r: quickstarts(d, "R").join("\n\n"),
};
const assets = [...d.data, ...d.additional_assets].map((asset) => ({
  asset,
  example: assetExample(d, asset),
}));
// The lead example ships expanded; the rest stay a click away
const firstExample = assets.findIndex((a) => a.example);

const SECTIONS = [
  ["overview", "Overview"],
  d.dimensions.length + d.variables.length > 0 && ["schema", "Schema"],
  d.data.length > 0 && ["access", "Access & use"],
  d.processing.length > 0 && ["provenance", "Provenance"],
  d.contact.length > 0 && ["contacts", "Contacts"],
  citation && ["citation", "Citation"],
].filter(Boolean) as [string, string][];

const jsonLd = datasetJsonLd(
  d,
  recordUrl,
  new URL("/catalog/", Astro.site).href,
);
---

<Layout
  description={d.description.slice(0, 160)}
  title={`${d.title} — ${SITE_NAME}`}
>
  <JsonLd data={jsonLd} slot="head" />

  <section class="header">
    <div class="container">
      <Breadcrumbs
        items={[{ label: "Hub", href: "/" }, { label: "Catalog", href: "/catalog/" }, { label: d.title }]}
      />
      <div class="header-grid">
        <div>
          <h1>{d.title}</h1>
          {source && <p class="source">{source}</p>}

          {d.version && (
            <div class="version-row">
              <span class="label">Version</span>
              {versions.length > 1 ? (
                <div class="seg version-toggle">
                  {versions.map((v, i) => (
                    <a
                      aria-current={v.id === d.id ? "page" : undefined}
                      href={`/catalog/${v.id}/`}
                    >
                      {v.version ?? v.id}
                      {i === 0 && <span class="latest">LATEST</span>}
                    </a>
                  ))}
                </div>
              ) : (
                <span class="version-single">{d.version}</span>
              )}
            </div>
          )}

          <div class="mono meta-row">
            <span class="fact">
              <span class="fact-label">license</span>
              {licenseHref ? (
                <a href={licenseHref} rel="noreferrer">{d.license}</a>
              ) : (
                d.license
              )}
            </span>
            {d.doi && (
              <span class="fact">
                <span class="fact-label">doi</span>
                <a href={`https://doi.org/${d.doi}`}>{d.doi}</a>
              </span>
            )}
            {d.updated && (
              <span class="fact">
                <span class="fact-label">updated</span>
                {d.updated}
              </span>
            )}
          </div>

          <div class="ctas">
            <a class="btn btn-primary" href="#access">Access the data</a>
            <a class="btn btn-ghost" href={`/catalog/${d.id}.json`}
              >View source</a
            >
            <a class="edit-link" href={GITHUB_URL}
              >Suggest an edit to this record</a
            >
          </div>
        </div>

        <div>
          <BboxMap bboxes={bboxes} label={coverage} />
          <div class="keywords">
            {d.keywords.map((k) =>
                typeof k === "string" ? (
                  <a class="mono keyword" href={`/catalog/?q=${encodeURIComponent(k)}`}>
                    #{k}
                  </a>
                ) : (
                  <a class="mono keyword ontology" href={k.uri ?? k.scheme} rel="noreferrer" title={`${k.scheme ?? "ontology"} concept`}>
                    {k.term} ↗
                  </a>
                ),
              )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <nav aria-label="Sections" class="section-nav">
    <div class="container">
      {SECTIONS.map(([id, label]) => <a href={`#${id}`}>{label}</a>)}
    </div>
  </nav>

  <div class="container body">
    <article>
      <section id="overview">
        <div class="prose" set:html={descriptionHtml} />

        {d.note && (
            <div class="note">
              <h3>Important note</h3>
              <p>{d.note}</p>
            </div>
          )}

        {(quickstart.python || quickstart.r) && (
            <div>
              <h3>Quick start</h3>
              <SnippetTabs python={quickstart.python} r={quickstart.r} />
              <p class="digest">
                <a href="#access">Full access details and endpoints</a>
              </p>
            </div>
          )}

        {d.cdh && d.cdh.use_cases.length > 0 && (
            <div>
              <h3>Good for</h3>
              <ul>
                {d.cdh.use_cases.map((u) => (
                  <li>{humanize(u)}</li>
                ))}
              </ul>
            </div>
          )}

        {d.cdh && d.cdh.not_recommended_for.length > 0 && (
            <div>
              <h3>Not recommended for</h3>
              <div class="warn-cards">
                {d.cdh.not_recommended_for.map((n) => (
                  <div class="warn-card">
                    <b>{humanize(n.use)}</b>
                    {n.reason && (
                      <p>
                        <b>Why:</b> {humanize(n.reason)}
                      </p>
                    )}
                    {n.use_instead && (
                      <p class="instead">
                        <b>Use instead:</b> {humanize(n.use_instead)}
                      </p>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

        {d.commodities.length > 0 && (
            <div>
              <h3>Commodities</h3>
              <div class="chips">
                {d.commodities.map((id) => {
                  const c = commodity(id);
                  return c?.uri ? (
                    <a class="chip" href={c.uri} rel="noreferrer" title={`AGROVOC ${c.code}`}>
                      {c.label} ↗
                    </a>
                  ) : (
                    <span class="chip">{c?.label ?? humanize(id)}</span>
                  );
                })}
              </div>
            </div>
          )}
      </section>

      {SECTIONS.some(([id]) => id === "schema") && (
          <section id="schema">
            {d.variables.length > 0 && (
              <div>
                <h3>Variables</h3>
                <div class="table-wrap">
                  <table>
                    <thead>
                      <tr>
                        <th>Variable</th>
                        <th>Type</th>
                        <th>Unit</th>
                        <th>Description</th>
                      </tr>
                    </thead>
                    <tbody>
                      {d.variables.map((v) => (
                        <tr>
                          <td class="mono var-name">{v.name}</td>
                          <td class="mono">{v.data_type ?? "—"}</td>
                          <td class="mono">{v.unit ?? "—"}</td>
                          <td>
                            {v.description ?? "—"}
                            {v.note && <div class="var-note">{v.note}</div>}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {d.dimensions.length > 0 && (
              <div>
                <h3>Dimensions</h3>
                <p class="section-sub">Axes of the cube — spatial, temporal, and domain axes.</p>
                <div class="dim-cards">
                  {d.dimensions.map((dim) => (
                    <div class="dim-card">
                      <div class="dim-head">
                        <span class="mono dim-name">{dim.name}</span>
                        {dim.type && <span class="label">{dim.type}</span>}
                      </div>
                      {dim.description && <p>{dim.description}</p>}
                      {dim.values.length > 0 && (
                        <div class="chips">
                          {dim.values.map((v) => (
                            <span class="chip mono">{v}</span>
                          ))}
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </section>
        )}

      {d.data.length > 0 && (
          <section id="access">
            <h3>Access &amp; use</h3>
            <p class="section-sub">
              Cloud-optimised distributions — read just the window you need directly from object
              storage.
            </p>
            {d.data.some((a) => a.href_template) && (
              <p class="digest">
                Machine-readable file index:{" "}
                <a href={stacCollectionUrl(d.id)} rel="noreferrer">STAC Collection</a>
              </p>
            )}

            <div class="assets">
              {assets.map(({ asset, example }, i) => (
                <div class="asset">
                  <div class="asset-head">
                    <span class="mono asset-name">{asset.name}</span>
                    {asset.media_type && <span class="pill spatial">{formatLabel(asset.media_type)}</span>}
                    {asset.file_size && <span class="mono asset-size">{asset.file_size}</span>}
                  </div>
                  {asset.description && <p>{asset.description}</p>}
                  {asset.href_template && <p class="mono pattern">pattern: {asset.href_template}</p>}
                  {asset.locations.map((loc) => (
                    <div class="endpoint">
                      <span class="mono proto">{loc.title ?? "URL"}</span>
                      <span class="mono url">{loc.url}</span>
                      <button class="btn btn-ghost copy" data-copy={loc.url} type="button">
                        Copy
                      </button>
                    </div>
                  ))}
                  {example && (
                    <details class="asset-example" open={i === firstExample}>
                      <summary>Example use</summary>
                      <SnippetTabs python={example.python} r={example.r} />
                    </details>
                  )}
                </div>
              ))}
            </div>
          </section>
        )}

      {d.processing.length > 0 && (
          <section id="provenance">
            <h3>Provenance</h3>
            <p class="section-sub">Ordered processing steps, from source to publication.</p>
            <ol class="lineage">
              {d.processing.map((step) => (
                <li>
                  <div class="step">
                    <div class="step-head">
                      <span class="mono step-id">{step.id}</span>
                      {step.date && <span class="label">{step.date.slice(0, 10)}</span>}
                    </div>
                    {step.description && <p>{step.description}</p>}
                    {step.derived_from.length > 0 && (
                      <p class="step-meta">
                        Derived from:{" "}
                        {step.derived_from.map((src, i) => (
                          <>
                            {i > 0 && ", "}
                            <a href={src.url} rel="noreferrer">
                              {src.title ?? src.url}
                            </a>
                          </>
                        ))}
                      </p>
                    )}
                    {step.code && (
                      <p class="step-meta mono">
                        code: <a href={step.code.url} rel="noreferrer">{step.code.url}</a>
                        {step.code.version && <span> @ {step.code.version}</span>}
                      </p>
                    )}
                  </div>
                </li>
              ))}
            </ol>
          </section>
        )}

      {d.contact.length > 0 && (
          <section id="contacts">
            <h3>Contacts</h3>
            <p class="section-sub">
              Who produced this dataset, and who to reach about it.
            </p>
            <div class="contact-cards">
              {contacts.map((c) => (
                <div class:list={["contact-card", c.roles.includes("custodian") && "custodian"]}>
                  <div class="contact-head">
                    <b>{c.name ?? c.organization}</b>
                    <span class="badges">
                      {c.roles.includes("custodian") && (
                        <span class="role-badge custodian-badge">Hub custodian</span>
                      )}
                      {c.roles.includes("licensor") && (
                        <span class="role-badge licensor-badge">Licensor</span>
                      )}
                    </span>
                  </div>
                  {c.name && c.organization && (
                    <div class="contact-org">{c.organization}</div>
                  )}
                  {c.roles.filter((r) => r !== "custodian" && r !== "licensor")
                    .length > 0 && (
                    <div class="chips">
                      {c.roles
                        .filter((r) => r !== "custodian" && r !== "licensor")
                        .map((r) => (
                          <span class="chip">{humanize(r)}</span>
                        ))}
                    </div>
                  )}
                  {(c.email || c.url) && (
                    <div class="contact-links">
                      {c.email && <a href={`mailto:${c.email}`}>{c.email}</a>}
                      {c.url && (
                        <a href={c.url} rel="noreferrer">
                          {c.url.replace(/^https?:\/\//, "")} ↗
                        </a>
                      )}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </section>
        )}

      {citation && (
          <section id="citation">
            <h3>How to cite</h3>
            <p class="cite-note">
              Please cite the dataset and any associated peer-reviewed
              publications.
            </p>
            <blockquote class="cite">{citation}</blockquote>
            {bibtexStr && (
              <div data-code-label="BibTeX">
                <Code code={bibtexStr} lang="bibtex" theme="github-light" />
              </div>
            )}
            {d.related_publications.length > 0 && (
              <div>
                <h4>Related publications</h4>
                <ul>
                  {d.related_publications.map((pub) => (
                    <li>
                      {pub.citation && `${pub.citation.authors.join(", ")} (${pub.citation.date}). ${pub.citation.title}. ${pub.citation.publisher}. `}
                      {pub.doi && <a href={`https://doi.org/${pub.doi}`}>doi:{pub.doi}</a>}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </section>
        )}
    </article>

    <aside>
      <div class="rail-box">
        <h4 class="label">Quick facts</h4>
        <dl class="kv">
          {coverage && (
            <>
              <dt>Coverage</dt>
              <dd>{coverage}</dd>
            </>
          )}
          {resolution && (
            <>
              <dt>Resolution</dt>
              <dd>{resolution}</dd>
            </>
          )}
          {d.spatial?.crs && (
            <>
              <dt>CRS</dt>
              <dd>
                {/^EPSG:\d+$/.test(d.spatial.crs) ? (
                  <a href={`https://epsg.io/${d.spatial.crs.split(":")[1]}`} rel="noreferrer">
                    {d.spatial.crs}
                  </a>
                ) : (
                  d.spatial.crs
                )}
              </dd>
            </>
          )}
          {temporal && (
            <>
              <dt>Temporal</dt>
              <dd>
                {temporal.main}
                {temporal.sub && <div class="fact-sub">{temporal.sub}</div>}
              </dd>
            </>
          )}
          {d.cdh && d.cdh.domain.length > 0 && (
            <>
              <dt>Domain</dt>
              <dd>{d.cdh.domain.map(humanize).join(", ")}</dd>
            </>
          )}
        </dl>
      </div>

      {tutorialLinks.length > 0 && (
          <div class="rail-box">
            <h4 class="label">Tutorials</h4>
            {tutorialLinks.map((t) => (
              <a class="rail-link" href={t.href}>
                <b>{t.title}</b>
                <span>{t.meta}</span>
              </a>
            ))}
          </div>
        )}

      {seenIn.length > 0 && (
          <div class="rail-box">
            <h4 class="label">Seen in</h4>
            {seenIn.map((uc) => (
              <a class="rail-link" href={uc.href}>
                <b>{uc.title}</b>
                <span>{uc.partner}</span>
              </a>
            ))}
          </div>
        )}

      {d.additional_links.length > 0 && (
          <div class="rail-box">
            <h4 class="label">Related links</h4>
            {d.additional_links.map((link) => (
              <a class="rail-link ext" href={link.url} rel="noreferrer">
                {link.name ?? link.url} ↗
              </a>
            ))}
          </div>
        )}
    </aside>
  </div>
</Layout>

<script>
// Hash-driven tabs: all panels stay in the DOM (crawlers see everything);
// the hash picks the visible one, so /catalog/<id>#access deep-links work.
const tabs = [
  ...document.querySelectorAll<HTMLAnchorElement>(".section-nav a"),
];
const panels = tabs
  .map((a) => document.getElementById(a.hash.slice(1)))
  .filter((el): el is HTMLElement => el !== null);

function showPanel(id: string) {
  const target = panels.some((s) => s.id === id) ? id : panels[0]?.id;
  for (const s of panels) s.hidden = s.id !== target;
  for (const a of tabs)
    a.setAttribute("aria-current", String(a.hash === `#${target}`));
}
// Don't strand the reader mid-page: reveal the new panel top if it's off-screen
function snapToPanel() {
  const panel = panels.find((s) => !s.hidden);
  if (panel && panel.getBoundingClientRect().top < 130) panel.scrollIntoView();
}

if (tabs.length > 0) {
  // replaceState instead of a real navigation — skips the browser's anchor jump
  for (const a of tabs) {
    a.addEventListener("click", (e) => {
      e.preventDefault();
      history.replaceState(null, "", a.hash);
      showPanel(a.hash.slice(1));
      snapToPanel();
    });
  }
  // In-content links (Access the data / see the full schema) and back-forward
  addEventListener("hashchange", () => {
    showPanel(location.hash.slice(1));
    snapToPanel();
  });
  showPanel(location.hash.slice(1));
}

// Copy-to-clipboard for asset endpoint URLs
document.addEventListener("click", async (e) => {
  const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(
    "button[data-copy]",
  );
  if (!btn?.dataset.copy) return;
  await navigator.clipboard.writeText(btn.dataset.copy);
  const original = btn.textContent;
  btn.textContent = "Copied";
  setTimeout(() => {
    btn.textContent = original;
  }, 1200);
});
</script>

<style>
.header {
  padding: 24px 0 32px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
}

.header-grid {
  display: grid;

  /* Map shrinks 350→260 before the layout collapses (see media queries) */
  grid-template-columns: 1fr minmax(260px, 350px);
  gap: 40px;
  align-items: stretch;
  margin-top: 16px;
}

/* Anchor keywords to the row bottom so they end flush with the CTAs */
.header-grid > div:last-child {
  display: flex;
  flex-direction: column;
}

h1 {
  max-width: 760px;
  margin-top: 14px;
  font-size: clamp(28px, 3vw, 36px);
}

.keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding-top: 12px;
  margin-top: auto;
}

.keyword {
  padding: 2px 8px;
  font-size: 10.5px;
  color: var(--text-mute);
  background: var(--grey-1);
  border-radius: 6px;
}

.keyword:hover {
  text-decoration: none;
  background: var(--grey-2);
}

.keyword.ontology {
  color: var(--cdh-blue-700);
  background: transparent;
  border: 1px solid var(--cdh-blue-150);
}

.ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  margin-top: 24px;
}

.source {
  max-width: 640px;
  margin-top: 10px;
  font-size: 15px;
  color: var(--text-soft);
}

.version-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
  margin-top: 16px;
}

.version-row .label {
  color: var(--text-mute);
}

.version-single {
  font-size: 13px;
  color: var(--text);
}

.latest {
  padding: 1px 5px;
  font-size: 9.5px;
  font-weight: 700;
  color: var(--cdh-blue-700);
  letter-spacing: 0.04em;
  background: var(--cdh-blue-50);
  border-radius: 6px;
}

.version-toggle a[aria-current="page"] .latest {
  color: #fff;
  background: rgb(255 255 255 / 22%);
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 14px;
  margin-top: 16px;
}

.fact {
  display: inline-flex;
  gap: 6px;
  align-items: center;
  font-size: 11.5px;
  color: var(--text);
}

.fact + .fact {
  padding-left: 14px;
  border-left: 1px solid var(--border);
}

.fact-label {
  color: var(--text-mute);
}

.section-nav {
  position: sticky;
  top: var(--nav-height);
  z-index: 10;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
}

.section-nav .container {
  display: flex;
  flex-wrap: wrap;
}

.section-nav a {
  padding: 14px 16px;
  margin-bottom: -1px;
  font-size: 13px;
  font-weight: 600;
  color: var(--text-soft);
