---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("catalog");
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<Layout title={entry.data.title ?? entry.id} description={entry.data.description}>
  <h1>{entry.data.title ?? entry.id}</h1>
  {entry.data.description && <p>{entry.data.description}</p>}
  {/* ponytail: JSON collection has no markdown to render() — dump the record until a real catalog view exists */}
  <pre>{JSON.stringify(entry.data, null, 2)}</pre>
</Layout>
