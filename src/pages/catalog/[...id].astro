        )}

      {d.additional_links.length > 0 && (
          <div class="rail-box">
            <h4 class="label">Related links</h4>
            {d.additional_links.map((link) => (
              <a class="rail-link ext" href={link.url} rel="noreferrer">
                {link.name ?? link.url} ↗
              </a>
            ))}
          </div>
        )}

      {d.funding.length > 0 && (
          <div class="rail-box">
            <h4 class="label">Funding</h4>
            {d.funding.map((f) =>
              f.url ? (
                <a class="rail-link ext" href={f.url} rel="noreferrer">
                  {f.name} ↗
                </a>
              ) : (
                <div class="rail-text">{f.name}</div>
              ),
            )}
          </div>
        )}
    </aside>
  </div>
</Layout>

<script>
// Usage-example modals: native <dialog> handles backdrop/Esc/focus; this
// wires the open and close buttons plus backdrop-click dismiss.
document.addEventListener("click", (e) => {
  const target = e.target as HTMLElement;
  if (target.closest("[data-example-open]"))
    target.closest(".example-row")?.querySelector("dialog")?.showModal();
  if (target.closest("[data-example-close]")) target.closest("dialog")?.close();
  // A click on the dialog element itself is the backdrop, not its content
  if (target instanceof HTMLDialogElement) target.close();
});

// Dropdowns (version switcher, metadata menu): <details> handles open/toggle
// natively; this only adds light-dismiss on outside clicks.
const menus =
  document.querySelectorAll<HTMLDetailsElement>("details.drop-menu");
document.addEventListener("click", (e) => {
  for (const menu of menus)
    if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
});

// Template pickers: the selects fill the asset's href_template; the built
// URL feeds the row's copy button and download link
for (const picker of document.querySelectorAll<HTMLElement>(".tpl-picker")) {
  const update = () => {
    let file = picker.dataset.template ?? "";
    for (const sel of picker.querySelectorAll<HTMLSelectElement>(
      "select[data-tpl-dim]",
    ))
      file = file.replaceAll(`{${sel.dataset.tplDim}}`, sel.value);
    const url = (picker.dataset.root ?? "") + file;
    const urlEl = picker.querySelector<HTMLElement>("[data-tpl-url]");
    if (urlEl) urlEl.textContent = url;
    const copyBtn =
      picker.querySelector<HTMLButtonElement>("button[data-copy]");
    if (copyBtn) copyBtn.dataset.copy = url;
    const dl = picker.querySelector<HTMLAnchorElement>("a[download]");
    if (dl) dl.href = url;
    // The usage example bakes in the previous selection's filename — swap it
    // wherever it appears in the dialog's code so the example stays live
    const prev = picker.dataset.file;
    const dialog = picker.closest(".asset")?.querySelector("dialog");
    if (dialog && prev && prev !== file) {
      const walker = document.createTreeWalker(dialog, NodeFilter.SHOW_TEXT);
      while (walker.nextNode()) {
        const node = walker.currentNode;
        if (node.nodeValue?.includes(prev))
          node.nodeValue = node.nodeValue.replaceAll(prev, file);
      }
    }
    picker.dataset.file = file;
  };
  picker.addEventListener("change", update);
  update();
}

// Citation formats are prerendered panels; the select swaps them and the
// choice persists like the snippet language does
const citeSelect = document.querySelector<HTMLSelectElement>("#cite-format");
const citePanels = [
  ...document.querySelectorAll<HTMLElement>("[data-cite-panel]"),
];
const showCite = (fmt: string) => {
  for (const p of citePanels) p.hidden = p.dataset.citePanel !== fmt;
  if (citeSelect) citeSelect.value = fmt;
};
citeSelect?.addEventListener("change", () => {
  showCite(citeSelect.value);
  localStorage.setItem("cite-format", citeSelect.value);
});
const savedCite = localStorage.getItem("cite-format");
if (savedCite && citePanels.some((p) => p.dataset.citePanel === savedCite))
  showCite(savedCite);

// Hash-driven tabs: all panels stay in the DOM (crawlers see everything);
// the hash picks the visible one, so /catalog/<id>#access deep-links work.
const tabs = [
  ...document.querySelectorAll<HTMLAnchorElement>(".section-nav a"),
];
const panels = tabs
  .map((a) => document.getElementById(a.hash.slice(1)))
  .filter((el): el is HTMLElement => el !== null);

function showPanel(id: string) {
  const target = panels.some((s) => s.id === id) ? id : panels[0]?.id;
  for (const s of panels) s.hidden = s.id !== target;
  for (const a of tabs)
    a.setAttribute("aria-current", String(a.hash === `#${target}`));
}
// Don't strand the reader mid-page: reveal the new panel top if it's off-screen
function snapToPanel() {
  const panel = panels.find((s) => !s.hidden);
  if (panel && panel.getBoundingClientRect().top < 130) panel.scrollIntoView();
}

if (tabs.length > 0) {
  // replaceState instead of a real navigation — skips the browser's anchor jump
  for (const a of tabs) {
    a.addEventListener("click", (e) => {
      e.preventDefault();
      history.replaceState(null, "", a.hash);
      showPanel(a.hash.slice(1));
      snapToPanel();
    });
  }
  // In-content links (Access the data / see the full schema) and back-forward
  addEventListener("hashchange", () => {
    showPanel(location.hash.slice(1));
    snapToPanel();
  });
  showPanel(location.hash.slice(1));
}
</script>

