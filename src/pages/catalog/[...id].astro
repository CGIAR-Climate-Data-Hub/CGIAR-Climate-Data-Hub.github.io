                          .filter(Boolean)
                          .join(" · ")}
                      </dd>
                    </>
                  )}
                  {d.climate.downscaling && (
                    <>
                      <dt>Downscaling</dt>
                      <dd>
                        {[
                          d.climate.downscaling.method,
                          d.climate.downscaling.resolution,
