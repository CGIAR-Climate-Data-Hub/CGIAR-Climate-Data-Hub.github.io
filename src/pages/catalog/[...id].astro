                      </dd>
                    </>
                  )}
                  {bboxes && (
                    <>
                      <dt>Extent (W S E N)</dt>
                      <dd class="mono">
                        {bboxes.map((b) => `[${b.join(", ")}]`).join("  ")}
                      </dd>
                    </>
                  )}
                  {coverage && (
                    <>
                      <dt>Coverage</dt>
                      <dd>{coverage}</dd>
                    </>
                  )}
                  {d.spatial.resolution.map((r) => (
                    <>
                      <dt>Resolution{r.type ? ` (${r.type})` : ""}</dt>
                      <dd>
                        {r.label
                          ?? [r.value, r.unit].filter(Boolean).join(" ")}
                        {r.note && <div class="fact-sub">{r.note}</div>}
                      </dd>
                    </>
                  ))}
                </dl>
              </div>
            )}

            {d.temporal && (
              <div>
                <h4 class="tech-title">Temporal</h4>
                <dl class="kv">
                  <dt>Start</dt>
                  <dd class="mono">{d.temporal.start_date}</dd>
                  <dt>End</dt>
                  <dd class="mono">{d.temporal.end_date ?? "open (present)"}</dd>
                  {d.temporal.resolution?.step && (
                    <>
                      <dt>Step</dt>
                      <dd class="mono">{d.temporal.resolution.step}</dd>
                    </>
                  )}
                  {d.temporal.resolution
                    && d.temporal.resolution.values.length > 0 && (
                    <>
                      <dt>Slices</dt>
                      <dd class="mono">
                        {d.temporal.resolution.values.join(", ")}
                      </dd>
                    </>
                  )}
                  {d.temporal.resolution?.note && (
                    <>
                      <dt>Note</dt>
                      <dd>{d.temporal.resolution.note}</dd>
                    </>
                  )}
                </dl>
              </div>
            )}

            {d.climate && (
            <div>
              <h4 class="tech-title">Climate methods</h4>
              <dl class="kv">
                  {d.climate.mip_era && (
                    <>
                      <dt>MIP era</dt>
                      <dd>{d.climate.mip_era}</dd>
                    </>
                  )}
                  {d.climate.models.length > 0 && (
                    <>
                      <dt>Models</dt>
                      <dd class="mono">{d.climate.models.join(", ")}</dd>
                    </>
                  )}
                  {d.climate.scenarios.length > 0 && (
                    <>
                      <dt>Scenarios</dt>
                      <dd class="mono">{d.climate.scenarios.join(", ")}</dd>
                    </>
                  )}
                  {d.climate.baseline && (
                    <>
                      <dt>Baseline</dt>
                      <dd>
                        {d.climate.baseline.start_date.slice(0, 4)}
                        {d.climate.baseline.end_date
                          && ` – ${d.climate.baseline.end_date.slice(0, 4)}`}
                      </dd>
                    </>
                  )}
                  {d.climate.bias_adjustment && (
                    <>
                      <dt>Bias adjustment</dt>
                      <dd>
                        {[
                          d.climate.bias_adjustment.method,
                          d.climate.bias_adjustment.reference_dataset,
