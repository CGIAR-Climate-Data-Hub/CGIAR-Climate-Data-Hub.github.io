---
import { getCollection } from "astro:content";
import DataGlyph from "@/components/DataGlyph.astro";
import DatasetCard from "@/components/DatasetCard.astro";
import JsonLd from "@/components/JsonLd.astro";
import PageHead from "@/components/PageHead.astro";
import Layout from "@/layouts/Layout.astro";
import { commodityLabel, geoLabel, humanize, summarize } from "@/lib/catalog";
import { BBOX_PRESETS } from "@/lib/geo";
import { landPath } from "@/lib/map";
import { SITE_NAME } from "@/site.config";

const entries = await getCollection("catalog");
const datasets = entries
  .map(summarize)
  .sort((a, b) => b.updated.localeCompare(a.updated));

// Facets are compiled from the metadata actually present in the records.
function facetOf(
  key: string,
  title: string,
  get: (d: (typeof datasets)[number]) => string[],
  label: (value: string) => string = humanize,
) {
  const counts = new Map<string, number>();
  for (const d of datasets) {
    for (const value of new Set(get(d))) {
      counts.set(value, (counts.get(value) ?? 0) + 1);
    }
  }
  const values = [...counts]
    .map(([value, count]) => ({ value, label: label(value), count }))
    .sort((a, b) => a.label.localeCompare(b.label));
  return { key, title, values };
}

const facets = [
  facetOf("domain", "Domain", (d) => d.domains),
  facetOf("geography", "Geography", (d) => d.geographies, geoLabel),
  facetOf("commodity", "Commodity", (d) => d.commodityGroups, commodityLabel),
];

// Spatial-search minimap (equirectangular; lon/lat → svg coords)
const W = 220;
const H = 110;
const toSvg = (lon: number, lat: number) => [
  ((lon + 180) / 360) * W,
  ((90 - lat) / 180) * H,
];
const land = landPath(W, H);

const description =
  "Browse the Hub's harmonised climate and agriculture datasets — consistent metadata, licensing, and cloud-native access.";

const catalogSchema = {
  "@context": "https://schema.org",
  "@type": "DataCatalog",
  "@id": new URL("/catalog/", Astro.site).href,
  name: `${SITE_NAME} Catalog`,
  description,
  url: new URL("/catalog/", Astro.site).href,
  dataset: datasets.map((d) => ({
    "@type": "Dataset",
    name: d.title,
    description: d.description,
    url: new URL(`/catalog/${d.id}/`, Astro.site).href,
  })),
};
---

<Layout description={description} title={`Catalog — ${SITE_NAME}`}>
  <JsonLd data={catalogSchema} slot="head" />

  <PageHead
    breadcrumb={[{ label: "Hub", href: "/" }, { label: "Catalog" }]}
    kicker="The catalogue"
    sub="Browse the Hub's harmonised datasets — all with consistent metadata, licensing, and cloud-native access."
    title="Catalog"
  >
    <div class="head-actions" slot="right">
      <a class="btn btn-ghost btn-cta" href="/contribute/">Contribute</a>
      <a class="btn btn-primary" href="/wikis/">Standards</a>
    </div>
  </PageHead>

  <section class="toolbar">
    <div class="container toolbar-row">
      <div class="searchbox">
        <svg
          aria-hidden="true"
          fill="none"
          height="14"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          width="14"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input
          id="catalog-search"
          placeholder="Search datasets — name, source, variable, keyword…"
          type="search"
        >
      </div>
      <div class="layout-wrap">
        <span class="label">Layout</span>
        <div aria-label="Result layout" class="seg" role="group">
          {[
            ["grid", "Cards"],
            ["compact", "Compact"],
            ["table", "Table"],
          ].map(([key, label]) => (
            <button
              aria-pressed={key === "grid" ? "true" : "false"}
              data-layout={key}
              type="button"
            >
              {label}
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container body">
    <aside aria-label="Filters" class="facets">
      <details class="bbox-box" open>
        <summary>
          <span class="bbox-title">
            <svg
              aria-hidden="true"
              fill="none"
              height="14"
              stroke="currentColor"
              stroke-width="1.4"
              viewBox="0 0 16 16"
              width="14"
            >
              <rect
                height="9"
                stroke-dasharray="2 1.4"
                width="11"
                x="2.5"
                y="3.5"
              ></rect>
              <circle
                cx="2.5"
                cy="3.5"
                fill="currentColor"
                r="1"
                stroke="none"
              ></circle>
              <circle
                cx="13.5"
                cy="12.5"
                fill="currentColor"
                r="1"
                stroke="none"
              ></circle>
            </svg>
            Spatial search
            <span class="mono bbox-active" hidden id="bbox-active">active</span>
          </span>
          <svg
            aria-hidden="true"
            class="chev"
            fill="none"
            height="11"
            stroke="currentColor"
            stroke-width="2.4"
            viewBox="0 0 24 24"
            width="11"
          >
            <path d="M6 9l6 6 6-6"></path>
          </svg>
        </summary>
        <div class="bbox-body">
          <p class="bbox-hint">
            Click and drag on the map to draw a bounding box.
          </p>
          <svg
            aria-label="World map — drag to draw a bounding box"
            id="bbox-map"
            role="img"
            viewBox={`0 0 ${W} ${H}`}
          >
            <rect
              fill="rgb(99 169 254 / 6%)"
              height={H}
              width={W}
              x="0"
              y="0"
            ></rect>
            {[-120, -60, 0, 60, 120].map((lon) => <line stroke="rgb(101 127 114 / 18%)" stroke-width="0.4" x1={toSvg(lon, 0)[0]} x2={toSvg(lon, 0)[0]} y1="0" y2={H}></line>)}
            {[-60, -30, 30, 60].map((lat) => <line stroke="rgb(101 127 114 / 18%)" stroke-width="0.4" x1="0" x2={W} y1={toSvg(0, lat)[1]} y2={toSvg(0, lat)[1]}></line>)}
            <line
              stroke="rgb(101 127 114 / 32%)"
              stroke-dasharray="1 1"
              stroke-width="0.5"
              x1="0"
              x2={W}
              y1={H / 2}
              y2={H / 2}
            ></line>
            <path
              d={land}
              fill="rgb(10 44 85 / 16%)"
              stroke="rgb(10 44 85 / 38%)"
              stroke-linejoin="round"
              stroke-width="0.35"
            ></path>
            <rect
              fill="rgb(99 169 254 / 28%)"
              height="0"
              id="bbox-rect"
              style="display: none"
              stroke="var(--cdh-blue-700)"
              stroke-width="0.8"
              width="0"
              x="0"
              y="0"
            ></rect>
          </svg>
          <div class="bbox-presets">
            {BBOX_PRESETS.map((p) => (
                <button class="mono preset" data-bbox={p.bbox.join(" ")} type="button">
                  {p.name}
                </button>
              ))}
          </div>
          <div class="bbox-actions">
            <span class="bbox-count">Draw to filter</span>
            <button class="mono" hidden id="bbox-clear" type="button">
              Clear
            </button>
          </div>
        </div>
      </details>

      <details open>
        <summary>
          <span class="label">Temporal</span>
          <svg
            aria-hidden="true"
            class="chev"
            fill="none"
            height="11"
            stroke="currentColor"
            stroke-width="2.4"
            viewBox="0 0 24 24"
            width="11"
          >
            <path d="M6 9l6 6 6-6"></path>
          </svg>
        </summary>
        <div class="year-range">
          <input
            aria-label="From year"
            class="mono"
            id="year-from"
            max="2100"
            min="1900"
            placeholder="From"
            type="number"
          >
          <span class="year-sep">–</span>
          <input
            aria-label="To year"
            class="mono"
            id="year-to"
            max="2100"
            min="1900"
            placeholder="To"
            type="number"
          >
        </div>
      </details>

      {facets.map((facet) => (
          <details open={facet.key !== "commodity"}>
            <summary>
              <span class="label">{facet.title}</span>
              <svg aria-hidden="true" class="chev" fill="none" height="11" stroke="currentColor" stroke-width="2.4" viewBox="0 0 24 24" width="11">
                <path d="M6 9l6 6 6-6" />
              </svg>
            </summary>
            <div class="options">
              <button aria-pressed="true" class="facet-option" data-facet={facet.key} data-value="" type="button">
                <span>All</span>
                <span class="mono count">{datasets.length}</span>
              </button>
              {facet.values.map((v) => (
                <button aria-pressed="false" class="facet-option" data-facet={facet.key} data-value={v.value} type="button">
                  <span>{v.label}</span>
                  <span class="mono count">{v.count}</span>
                </button>
              ))}
            </div>
          </details>
        ))}
    </aside>

    <div>
      <div class="results-meta">
        <span
          ><b id="match-count">{datasets.length}</b>{" "}
          <span id="match-label">datasets</span></span
        >
        <button hidden id="clear-filters" type="button">
          Clear all filters
        </button>
      </div>
      <div class="mono table-head">
        <span>Type</span>
        <span>Name</span>
        <span>Coverage</span>
        <span>Resolution</span>
        <span>Temporal</span>
        <span>Updated</span>
      </div>
      <ul class="grid" data-pagefind-ignore id="results">
        {datasets.map((d) => (
            <li
              data-bbox={d.bboxes?.map((b) => b.join(" ")).join(";")}
              data-commodity={d.commodities.join(" ")}
              data-dataset
              data-domain={d.domains.join(" ")}
              data-geography={d.geographies.join(" ")}
              data-years={d.temporalYears?.join(" ")}
              data-search={[d.title, d.description, ...d.keywords, ...d.geographies.map(geoLabel), ...d.commodities.map(commodityLabel)].join(" ").toLowerCase()}
            >
              <DatasetCard dataset={d} />
              <a class="row-compact" href={`/catalog/${d.id}/`}>
                <DataGlyph type={d.type} />
                <span class="row-text">
                  <span class="row-title">{d.title}</span>
                  <span class="row-desc">{d.description}</span>
                </span>
                <span class="mono row-meta">
                  <span>{d.coverage ?? "—"}</span>
                  <span>{d.temporal ?? "—"}</span>
                </span>
              </a>
              <a class="row-table" href={`/catalog/${d.id}/`}>
                <span>
                  <span class:list={["pill", "dot", d.type]}
                    >{d.type === "spatial" ? "Spatial" : "Non-spatial"}</span
                  >
                </span>
                <span class="row-text">
                  <span class="row-title">{d.title}</span>
                  <span class="row-desc">{d.description}</span>
                </span>
                <span class="mono">{d.coverage ?? "—"}</span>
                <span class="mono">{d.resolution ?? "—"}</span>
                <span class="mono">{d.temporal ?? "—"}</span>
                <span class="mono">{d.updated.slice(0, 10) || "—"}</span>
              </a>
            </li>
          ))}
      </ul>
      <div class="empty" hidden id="empty-state">
        <h3>No matches.</h3>
        <p>Try removing a filter, or broaden your search.</p>
      </div>
    </div>
  </section>
</Layout>

<script>
// Layout switcher — a display preference, so it persists locally, not in the URL
const layoutButtons = [
  ...document.querySelectorAll<HTMLButtonElement>("[data-layout]"),
];
const results = document.querySelector("#results");
function setLayout(layout: string) {
  results?.classList.toggle("layout-compact", layout === "compact");
  results?.classList.toggle("layout-table", layout === "table");
  for (const b of layoutButtons)
    b.setAttribute("aria-pressed", String(b.dataset.layout === layout));
  localStorage.setItem("catalog-layout", layout);
}
for (const b of layoutButtons)
  b.addEventListener("click", () => setLayout(b.dataset.layout ?? "grid"));
const savedLayout = localStorage.getItem("catalog-layout");
if (savedLayout && savedLayout !== "grid") setLayout(savedLayout);

const cards = [...document.querySelectorAll<HTMLElement>("li[data-dataset]")];
const buttons = [
  ...document.querySelectorAll<HTMLButtonElement>(".facet-option"),
];
const search = document.querySelector<HTMLInputElement>("#catalog-search");
const clear = document.querySelector<HTMLButtonElement>("#clear-filters");
const count = document.querySelector("#match-count");
const matchLabel = document.querySelector("#match-label");
const empty = document.querySelector<HTMLElement>("#empty-state");

const facetKeys = ["domain", "geography", "commodity"] as const;
const state: {
  q: string;
  bbox: number[] | null;
  from: number | null;
  to: number | null;
  [key: string]: unknown;
} = {
  q: "",
  bbox: null,
  from: null,
  to: null,
};
const yearFrom = document.querySelector<HTMLInputElement>("#year-from");
const yearTo = document.querySelector<HTMLInputElement>("#year-to");

const bboxIntersects = (a: number[], b: number[]) =>
  !(a[2] < b[0] || a[0] > b[2] || a[3] < b[1] || a[1] > b[3]);

function matchesBbox(card: HTMLElement) {
  const drawn = state.bbox;
  if (!drawn) return true;
  const raw = card.dataset.bbox;
  // Datasets without a spatial extent can't intersect a drawn box
  if (!raw) return false;
  // A dataset may span several boxes (antimeridian splits, multi-region)
  return raw
    .split(";")
    .some((b) => bboxIntersects(b.split(" ").map(Number), drawn));
}

// Interval intersection, like the bbox but in one dimension
function matchesYears(card: HTMLElement) {
  if (state.from === null && state.to === null) return true;
  const raw = card.dataset.years;
  if (!raw) return false;
  const [start, end] = raw.split(" ").map(Number);
  return (
    (state.to === null || start <= state.to)
    && (state.from === null || end >= state.from)
  );
}

function apply() {
  let matched = 0;
  for (const card of cards) {
    const show =
      facetKeys.every((k) => {
        if (!state[k]) return true;
        const values = (card.dataset[k] ?? "").split(" ");
        // Global datasets cover every geography
        if (k === "geography" && values.includes("world")) return true;
        return values.includes(state[k] as string);
      })
      && (!state.q || (card.dataset.search ?? "").includes(state.q))
      && matchesBbox(card)
      && matchesYears(card);
    card.hidden = !show;
    if (show) matched++;
  }
  if (count) count.textContent = String(matched);
  if (matchLabel)
    matchLabel.textContent = matched === 1 ? "dataset" : "datasets";
  if (empty) empty.hidden = matched > 0;
  for (const b of buttons) {
    b.setAttribute(
      "aria-pressed",
      String(state[b.dataset.facet ?? ""] === b.dataset.value),
    );
  }
  if (clear)
    clear.hidden =
      !state.q
      && !state.bbox
      && state.from === null
      && state.to === null
      && facetKeys.every((k) => !state[k]);
  syncBboxUi();

  // Keep filters shareable
  const params = new URLSearchParams();
  if (state.q) params.set("q", state.q);
  for (const k of facetKeys) if (state[k]) params.set(k, state[k] as string);
  if (state.bbox)
    params.set("bbox", state.bbox.map((n) => n.toFixed(2)).join(","));
  if (state.from !== null || state.to !== null)
    params.set("years", `${state.from ?? ""}-${state.to ?? ""}`);
  history.replaceState(
    null,
    "",
    params.size ? `?${params}` : location.pathname,
  );
}

for (const b of buttons) {
  b.addEventListener("click", () => {
    state[b.dataset.facet ?? ""] = b.dataset.value ?? "";
    apply();
  });
}
search?.addEventListener("input", () => {
  state.q = search.value.trim().toLowerCase();
  apply();
});
for (const input of [yearFrom, yearTo]) {
  input?.addEventListener("input", () => {
    state.from = yearFrom?.value ? +yearFrom.value : null;
    state.to = yearTo?.value ? +yearTo.value : null;
    apply();
  });
}
clear?.addEventListener("click", () => {
  for (const k of facetKeys) state[k] = "";
  state.q = "";
  state.bbox = null;
  state.from = null;
  state.to = null;
  if (search) search.value = "";
  if (yearFrom) yearFrom.value = "";
  if (yearTo) yearTo.value = "";
  apply();
});

// ---- Spatial (bbox) search: drag a rectangle on the minimap ----
const map = document.querySelector<SVGSVGElement>("#bbox-map");
const rect = document.querySelector<SVGRectElement>("#bbox-rect");
const activeTag = document.querySelector<HTMLElement>("#bbox-active");
const bboxClear = document.querySelector<HTMLButtonElement>("#bbox-clear");
const hint = document.querySelector<HTMLElement>(".bbox-hint");

const MAP_W = 220;
const MAP_H = 110;
const toLonLat = (x: number, y: number) => [
  -180 + (x / MAP_W) * 360,
  90 - (y / MAP_H) * 180,
];
const toSvgPt = (lon: number, lat: number) => [
  ((lon + 180) / 360) * MAP_W,
  ((90 - lat) / 180) * MAP_H,
];

function svgPoint(e: PointerEvent) {
  if (!map) return [0, 0];
  const r = map.getBoundingClientRect();
  const x = ((e.clientX - r.left) / r.width) * MAP_W;
  const y = ((e.clientY - r.top) / r.height) * MAP_H;
  return [Math.max(0, Math.min(MAP_W, x)), Math.max(0, Math.min(MAP_H, y))];
}

function drawRect(x: number, y: number, w: number, h: number) {
  if (!rect) return;
  rect.style.display = "";
  rect.setAttribute("x", String(x));
  rect.setAttribute("y", String(y));
  rect.setAttribute("width", String(w));
  rect.setAttribute("height", String(h));
}

function syncBboxUi() {
  const active = state.bbox !== null;
  if (activeTag) activeTag.hidden = !active;
  if (bboxClear) bboxClear.hidden = !active;
  if (hint) {
    hint.textContent = active
      ? "Datasets whose coverage intersects your box."
      : "Click and drag on the map to draw a bounding box.";
  }
  if (state.bbox) {
    const [w, s, e, n] = state.bbox;
    const [x1, y1] = toSvgPt(w, n);
    const [x2, y2] = toSvgPt(e, s);
    drawRect(x1, y1, x2 - x1, y2 - y1);
  } else if (rect) {
    rect.style.display = "none";
  }
}

let dragStart: number[] | null = null;
map?.addEventListener("pointerdown", (e) => {
  e.preventDefault();
  map.setPointerCapture(e.pointerId);
  dragStart = svgPoint(e);
});
map?.addEventListener("pointermove", (e) => {
  if (!dragStart) return;
  const p = svgPoint(e);
  drawRect(
    Math.min(dragStart[0], p[0]),
    Math.min(dragStart[1], p[1]),
    Math.abs(dragStart[0] - p[0]),
    Math.abs(dragStart[1] - p[1]),
  );
});
map?.addEventListener("pointerup", (e) => {
  if (!dragStart) return;
  const p = svgPoint(e);
  const dx = Math.abs(dragStart[0] - p[0]);
  const dy = Math.abs(dragStart[1] - p[1]);
  if (dx > 2 && dy > 2) {
    const [w, n] = toLonLat(
      Math.min(dragStart[0], p[0]),
      Math.min(dragStart[1], p[1]),
    );
    const [e2, s] = toLonLat(
      Math.max(dragStart[0], p[0]),
      Math.max(dragStart[1], p[1]),
    );
    state.bbox = [w, s, e2, n];
  }
  dragStart = null;
  apply();
});

for (const preset of document.querySelectorAll<HTMLButtonElement>(".preset")) {
  preset.addEventListener("click", () => {
    state.bbox = (preset.dataset.bbox ?? "").split(" ").map(Number);
    apply();
  });
}
bboxClear?.addEventListener("click", () => {
  state.bbox = null;
  apply();
});

// ---- Init from URL ----
// Filters start collapsed on small screens so results stay above the fold
if (matchMedia("(max-width: 860px)").matches) {
  for (const d of document.querySelectorAll("aside details[open]")) {
    d.removeAttribute("open");
  }
}

const params = new URLSearchParams(location.search);
state.q = (params.get("q") ?? "").trim().toLowerCase();
if (search) search.value = params.get("q") ?? "";
for (const k of facetKeys) state[k] = params.get(k) ?? "";
const urlBbox = params.get("bbox")?.split(",").map(Number);
if (urlBbox?.length === 4 && urlBbox.every((n) => !Number.isNaN(n)))
  state.bbox = urlBbox;
const urlYears = params.get("years")?.split("-");
if (urlYears?.length === 2) {
  state.from = urlYears[0] ? +urlYears[0] : null;
  state.to = urlYears[1] ? +urlYears[1] : null;
  if (yearFrom && state.from !== null) yearFrom.value = String(state.from);
  if (yearTo && state.to !== null) yearTo.value = String(state.to);
}
apply();
</script>

<style>
.head-actions {
  display: flex;
  gap: 8px;
}

.toolbar {
  margin-top: 28px;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.toolbar-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  padding-top: 16px;
  padding-bottom: 16px;
}

.searchbox {
  display: flex;
  flex: 1 1 360px;
  gap: 8px;
  align-items: center;
  min-width: 280px;
  max-width: 560px;
  padding: 8px 12px;
  color: var(--grey-6);
  background: var(--surface);
  border: 1px solid var(--border-strong);
  border-radius: 6px;
}

.searchbox input {
  flex: 1;
  font-size: 14px;
  outline: 0;
  background: transparent;
  border: 0;
}

.body {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 32px;
  padding-top: 32px;
}

/* ---- Spatial search ---- */
.bbox-box {
  padding: 0;
  margin-bottom: 20px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
}

.bbox-box summary {
  padding: 10px 12px;
}

.bbox-title {
  display: inline-flex;
  gap: 8px;
  align-items: center;
  font-size: 13px;
  font-weight: 600;
}

.bbox-active {
  padding: 1px 6px;
  font-size: 10px;
  color: #fff;
  background: var(--cdh-blue-700);
  border-radius: 6px;
}

.bbox-body {
  padding: 0 12px 12px;
}

.bbox-hint {
  margin-bottom: 8px;
  font-size: 11px;
  line-height: 1.45;
  color: var(--text-mute);
}

#bbox-map {
  display: block;
  width: 100%;
  height: auto;
  touch-action: none;
  cursor: crosshair;
  user-select: none;
  background: var(--bg);
  border: 1px solid var(--border);
}

.bbox-presets {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-top: 8px;
}

.preset {
