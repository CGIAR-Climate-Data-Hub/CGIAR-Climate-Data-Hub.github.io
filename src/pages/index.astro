---
import { getCollection } from "astro:content";
import PagefindConfig from "astro-pagefind/components/PagefindConfig.astro";
import DataGlyph from "@/components/DataGlyph.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import Layout from "@/layouts/Layout.astro";
import { currentReleases, summarize } from "@/lib/catalog";
import { allTutorials } from "@/lib/collections";
import { GITHUB_URL, SITE_NAME } from "@/site.config";

// The two most recently updated releases represent the catalog here
const datasets = currentReleases(await getCollection("catalog"))
  .map(summarize)
  .sort((a, b) => b.updated.localeCompare(a.updated))
  .slice(0, 2);
const tutorials = (await allTutorials()).sort(
  (a, b) => b.data.updated.valueOf() - a.data.updated.valueOf(),
);
const wikis = (await getCollection("wikis"))
  .filter((w) => w.data.order)
  .slice(0, 2);

// One begin-here list mixing the collections; grows with the content.
const essentials = [
  ...datasets.map((d) => ({
    href: `/catalog/${d.id}/`,
    name: d.title,
    badge: d.type === "spatial" ? "Spatial" : "Tabular",
    badgeClass: d.type,
    meta: [d.coverage, d.temporal].filter(Boolean).join(" · "),
    glyph: d.type,
  })),
  ...tutorials.slice(0, 2).map((t) => ({
    href: `/tutorials/${t.id}/`,
    name: t.data.title,
    badge: "Tutorial",
    badgeClass: "warn",
    meta: `${t.data.level} · ${t.data.time}`,
    glyph: undefined,
  })),
  ...wikis.map((w) => ({
    href: `/wikis/${w.id}/`,
    name: w.data.title,
    badge: "Wiki",
    badgeClass: "",
    meta: w.data.section,
    glyph: undefined,
  })),
];

const PATHS = [
  {
    href: "/catalog/",
    glyph: "search",
    label: "Find a specific dataset",
    cue: "Search & filter",
  },
  {
    href: "/tutorials/",
    glyph: "book",
    label: "Learn how to use the data",
    cue: "Runnable tutorials",
  },
  {
    href: "/use-cases/",
    glyph: "layers",
    label: "See it working in the field",
    cue: "Use cases",
  },
  {
    href: "/contribute/",
    glyph: "upload",
    label: "Contribute data or docs",
    cue: "Add to the Commons",
  },
  {
    href: "/ai/",
    glyph: "spark",
    label: "Use the Commons with AI",
    cue: "Skills & agent access",
  },
];

const TRY_CHIPS = ["livestock", "crop production", "gridded", "exposure"];

const PRINCIPLES = [
  [
    "Quality-assured",
    "Every dataset is reviewed, documented and versioned before it lands — so you can trust what you build on.",
  ],
  [
    "One shared standard",
    "STAC items and a common schema mean discovery, citation and access work the same way for every layer.",
  ],
  [
    "Openly licensed",
    "CC-BY by default. Cite the source and reuse freely — for research, decision-support or finance.",
  ],
  [
    "Cloud-native & interoperable",
    "COG and Zarr: query data where it lives, or stream just the window you need — no bespoke plumbing.",
  ],
];

const GLYPHS: Record<string, string> = {
  search: "M11 4a7 7 0 1 1 0 14 7 7 0 0 1 0-14Zm10 17-4.3-4.3",
  book: "M4 5a2 2 0 0 1 2-2h14v16H6a2 2 0 0 0-2 2V5Zm2 14h14M8 7h8",
  layers: "m12 3 9 5-9 5-9-5 9-5Zm-9 9 9 5 9-5",
  upload: "M12 16V4m0 0L7 9m5-5 5 5M5 20h14",
  spark:
    "M12 3c.7 4.2 2.8 6.3 7 7-4.2.7-6.3 2.8-7 7-.7-4.2-2.8-6.3-7-7 4.2-.7 6.3-2.8 7-7Z",
};
---

<Layout title={`${SITE_NAME} — Climate evidence, decision-ready`}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="statement">
        <div class="label kicker">CGIAR · Climate Action</div>
        <h1>Climate evidence,<br>decision-ready.</h1>
        <p class="lede">
          One quality-assured home for climate data, tools, and documentation
          across CGIAR — consistently formatted, openly licensed, and ready to
          use.
        </p>

        <PagefindConfig instance="hero" />
        <pagefind-searchbox
          class="paper-search"
          instance="hero"
          placeholder="Search datasets, docs, and tutorials"
          shortcut="/"
        ></pagefind-searchbox>

        <div class="try-row">
          <span class="label">Try</span>
          {TRY_CHIPS.map((chip) => <a class="try-chip" href={`/search/?q=${encodeURIComponent(chip)}`}>{chip}</a>)}
        </div>
      </div>

      <div class="paths">
        <div class="label kicker start-here">Start here</div>
        {PATHS.map((p) => (
            <a class="path" href={p.href}>
              <svg aria-hidden="true" class="path-glyph" fill="none" height="21" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" viewBox="0 0 24 24" width="21">
                <path d={GLYPHS[p.glyph]} />
              </svg>
              <span class="path-text">
                <span class="path-label">{p.label}</span>
                <span class="label path-cue">{p.cue}</span>
              </span>
              <svg aria-hidden="true" class="path-arrow" fill="none" height="17" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="17">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </a>
          ))}
      </div>
    </div>
  </section>

  <section class="essentials">
    <div class="container">
      <SectionHeader
        kicker="Start with the essentials"
        sub="Not looking for something specific yet? Start here — a curated mix of the data and documentation most climate work on the Commons is built on."
        title="A place to begin"
      >
        <a class="btn btn-ghost" href="/catalog/" slot="right"
          >Browse everything →</a
        >
      </SectionHeader>

      <div class="essentials-grid">
        {essentials.map((item) => (
            <a class="essential" href={item.href}>
              <span class:list={["essential-glyph", item.glyph ?? "doc"]}>
                {item.glyph ? (
                  <DataGlyph size={19} type={item.glyph} />
                ) : (
                  <svg aria-hidden="true" fill="none" height="19" stroke="currentColor" stroke-linecap="round" stroke-width="1.6" viewBox="0 0 24 24" width="19">
                    <path d="M7 3h7l5 5v13H7V3Zm7 0v5h5M10 12h6M10 16h6" />
                  </svg>
                )}
              </span>
              <span class="essential-text">
                <span class="essential-name">{item.name}</span>
                <span class="essential-meta">
                  <span class:list={["pill", "dot", item.badgeClass]}>{item.badge}</span>
                  <span class="mono">{item.meta}</span>
                </span>
              </span>
              <svg aria-hidden="true" class="essential-arrow" fill="none" height="16" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="16">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </a>
          ))}
      </div>
    </div>
  </section>

  <section class="principles">
    <div class="container">
      <div class="principles-band">
        <div>
          <div class="label band-kicker">Why the Commons works this way</div>
          <h2>Findable once.<br>Usable everywhere.</h2>
          <p class="band-lede">
            Climate evidence across CGIAR used to live in scattered formats and
            portals. The Commons brings it under one set of principles, so teams
            can build on each other's work instead of starting over.
          </p>
          <a class="band-link" href="/about/">More about the Commons →</a>
        </div>
        <div>
          {PRINCIPLES.map(([title, body], i) => (
              <div class="principle">
                <span class="mono principle-n">{String(i + 1).padStart(2, "0")}</span>
                <div>
                  <div class="principle-title">{title}</div>
                  <p>{body}</p>
                </div>
              </div>
            ))}
        </div>
      </div>
    </div>
  </section>

  <section class="contribute">
    <div class="container contribute-band">
      <div>
        <h2>The Commons grows because people add to it.</h2>
        <p>
          If your team holds climate-relevant data, a reusable tool, or a story
          worth telling, there is a clear path in.
        </p>
      </div>
      <div class="contribute-ctas">
        <a class="btn btn-accent" href="/contribute/">Contribute a dataset</a>
        <a class="btn btn-ghost" href={GITHUB_URL}>Open on GitHub</a>
      </div>
    </div>
  </section>
</Layout>

<style>
/* ---- Hero: paper statement + program-blue sweep on the right ---- */
/* No overflow clipping here — the searchbox dropdown must extend past the
   hero's bottom edge. The ::before gradient is inset: 0, so it can't leak. */
.hero {
  position: relative;
}

.hero::before {
  position: absolute;
  inset: 0;
  pointer-events: none;
  content: "";
  background: linear-gradient(
    90deg,
    transparent 28%,
    rgb(99 169 254 / 9%) 48%,
    rgb(99 169 254 / 24%) 72%,
    rgb(99 169 254 / 46%) 100%
  );
}

.hero-grid {
  position: relative;
  display: grid;
  grid-template-columns: 1.35fr 1fr;
  gap: 72px;
  align-items: center;
  padding-top: 84px;
  padding-bottom: 72px;
}

.statement {
  max-width: 620px;
}

h1 {
  font-size: clamp(38px, 4.4vw, 58px);
  letter-spacing: -0.025em;
}

.lede {
  max-width: 540px;
  margin-top: 24px;
  font-family: var(--serif);
  font-size: 18px;
  font-weight: 300;
  line-height: 1.6;
  color: var(--text-soft);
}

/* The searchbox renders its input at runtime, so inner parts are styled
   via :global to keep the hero's paper look. */
.paper-search {
  display: block;
  min-height: 59px; /* input height, reserved so JS render doesn't shift layout */
  margin-top: 32px;
}

.paper-search :global(.pf-searchbox-input-wrapper) {
  display: flex;
  align-items: center;
  padding-right: 14px;
  background: var(--surface);
  border: 1.5px solid var(--border-strong);
  border-radius: var(--input-radius);
  box-shadow: 0 1px 2px rgb(20 16 8 / 3%);
  transition:
    border-color 0.16s,
    box-shadow 0.16s;
}

.paper-search :global(.pf-searchbox-input-wrapper:focus-within) {
  border-color: var(--cdh-blue-700);
  box-shadow: 0 8px 30px rgb(15 46 78 / 10%);
}

.paper-search :global(.pf-searchbox-input) {
  flex: 1;
  min-width: 0;
  padding: 18px 22px;
  font-size: 16.5px;
  color: var(--text);
  outline: 0;
  background: transparent;
  border: 0;
}

.try-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
  margin-top: 18px;
}

.try-row .label {
  font-size: 10.5px;
  color: var(--text-mute);
}

.try-chip {
  padding: 5px 13px;
  font-size: 12.5px;
  color: var(--text-soft);
  border: 1px solid var(--border-strong);
  border-radius: var(--chip-radius);
  transition:
    border-color 0.12s,
    color 0.12s,
    background 0.12s;
}

.try-chip:hover {
  color: var(--cdh-blue-800);
  text-decoration: none;
  background: var(--cdh-blue-50);
  border-color: var(--cdh-blue-300);
}

/* ---- Start-here rail ---- */
.paths {
  padding-left: 44px;
  border-left: 1px solid var(--border);
}

.kicker.start-here {
  margin-bottom: 6px;
  color: var(--terra-500);
}

.path {
  display: flex;
  gap: 16px;
  align-items: center;
  padding: 18px 4px;
  color: var(--text);
  border-top: 1px solid var(--border);
  transition: padding-left 0.16s;
}

.path:first-of-type {
  border-top: 0;
}

.path:hover {
  padding-left: 12px;
  text-decoration: none;
}

.path-glyph {
  flex-shrink: 0;
  color: var(--cdh-blue-700);
  transition: color 0.16s;
}

.path-text {
  flex: 1;
  min-width: 0;
}

.path-label {
  display: block;
  font-family: var(--serif);
  font-size: 18.5px;
  font-weight: 500;
  line-height: 1.25;
  color: var(--cdh-blue-950);
}

.path-cue {
  display: block;
  margin-top: 4px;
  font-size: 10px;
  color: var(--text-mute);
}

.path-arrow {
  flex-shrink: 0;
  color: var(--text-mute);
  transition:
    transform 0.16s,
    color 0.16s;
}

.path:hover .path-glyph,
.path:hover .path-arrow {
  color: var(--terra-700);
}

.path:hover .path-arrow {
  transform: translateX(4px);
}

/* ---- Essentials ---- */
.essentials {
  padding: 84px 0 8px;
}

.essentials-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  column-gap: 56px;
  border-top: 1px solid var(--border);
}

.essential {
  display: grid;
  grid-template-columns: 40px 1fr auto;
  gap: 16px;
  align-items: center;
  padding: 18px 6px;
  color: var(--text);
  border-bottom: 1px solid var(--border);
  transition: background 0.12s;
}

.essential:hover {
  text-decoration: none;
  background: var(--surface);
}

.essential-glyph {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 10px;
}

.essential-glyph.doc {
  color: var(--terra-700);
  background: var(--terra-50);
}

.essential-text {
  min-width: 0;
}

.essential-name {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 15.5px;
  font-weight: 600;
  color: var(--cdh-blue-950);
  white-space: nowrap;
}

.essential-meta {
  display: flex;
  gap: 9px;
  align-items: center;
  margin-top: 4px;
}

.essential-meta .mono {
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 11.5px;
  color: var(--text-mute);
  white-space: nowrap;
}

.essential-arrow {
  color: var(--text-mute);
}

/* ---- Principles band (navy — text is white or #63A9FE only) ---- */
.principles {
  padding: 72px 0 8px;
}

.principles-band {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 56px;
  align-items: start;
  padding: 52px 56px;
  overflow: hidden;
  color: #fff;
  background: var(--cdh-blue-950);
  border-radius: 16px;
}

.band-kicker {
  margin-bottom: 16px;
  color: var(--cdh-blue-300);
}

.principles-band h2 {
  font-size: 31px;
  line-height: 1.15;
  color: #fff;
}

.band-lede {
  max-width: 400px;
  margin-top: 16px;
  font-size: 15.5px;
  line-height: 1.65;
  color: rgb(255 255 255 / 76%);
}

.band-link {
  display: inline-block;
  margin-top: 22px;
  font-size: 14.5px;
  font-weight: 600;
  color: var(--cdh-blue-300);
}

.principle {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 18px;
  align-items: baseline;
  padding: 18px 0;
  border-top: 1px solid rgb(255 255 255 / 12%);
}

.principle:first-child {
  border-top: 0;
}

.principle-n {
  font-size: 11px;
  color: var(--terra-300);
}

.principle-title {
  font-family: var(--serif);
  font-size: 19px;
  font-weight: 500;
  color: #fff;
}

.principle p {
  margin-top: 5px;
  font-size: 14px;
  line-height: 1.6;
  color: rgb(255 255 255 / 72%);
}

/* ---- Contribute band ---- */
.contribute {
  padding: 72px 0 8px;
}

.contribute-band {
  display: flex;
  flex-wrap: wrap;
  gap: 40px;
  align-items: center;
  justify-content: space-between;
  padding-top: 40px;
  border-top: 1px solid var(--border);
}

.contribute-band h2 {
  font-size: 30px;
}

.contribute-band p {
  max-width: 620px;
  margin-top: 12px;
  font-size: 16px;
  line-height: 1.6;
  color: var(--text-soft);
}

.contribute-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

@media (width <= 960px) {
  .hero-grid {
    grid-template-columns: 1fr;
    gap: 40px;
    padding-top: 48px;
  }

  .paths {
    padding-left: 0;
    border-left: 0;
  }

  .essentials-grid {
    grid-template-columns: 1fr;
  }

  .principles-band {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 36px 28px;
  }
}
</style>
