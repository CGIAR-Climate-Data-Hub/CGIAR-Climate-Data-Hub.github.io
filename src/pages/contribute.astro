---
import { getCollection } from "astro:content";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import Layout from "@/layouts/Layout.astro";
import { GITHUB_URL, SITE_NAME } from "@/site.config";

const guides = (await getCollection("contributionGuides"))
  .sort((a, b) => a.data.order - b.data.order)
  .map(({ id, data }) => ({ id, ...data }));

const STANDARDS_LINKS = [
  ["Metadata standard", "/wikis/cdh-metadata-standard"],
  ["STAC profile", "/wikis/stac-profile"],
  ["COG authoring", "/wikis/cog-authoring"],
  ["Licensing & attribution", "/wikis/licensing-and-attribution"],
];

const REPORT_KINDS = [
  ["Dataset issue", "Wrong values, broken access, metadata error"],
  ["Website / UX bug", "Broken link, layout, search, accessibility"],
  ["Wiki / docs error", "Outdated, incorrect, or missing documentation"],
  ["Something else", "Doesn't fit any of the above"],
];

const description =
  "How to contribute a dataset, edit the docs, submit a use case, or report an issue on the Climate Data Hub.";
---

<Layout description={description} title={`Contribute — ${SITE_NAME}`}>
  <section class="hero">
    <div class="container">
      <Breadcrumbs
        items={[{ label: "Hub", href: "/" }, { label: "Contribute" }]}
      />
      <div class="hero-grid">
        <div>
          <h1>Contribute to the Hub.</h1>
          <p class="hero-lede">
            The Hub grows because Centers, programmes and partners contribute.
            Whether you're publishing a new dataset, editing a wiki, or telling
            the story of how the Hub helped your project — there's a path for
            you.
          </p>
        </div>
        <div class="help-box">
          <div class="label">Need help?</div>
          <p>
            Reach the Hub stewardship team on the #cdh-stewardship Teams
            channel, or
            <a href={`${GITHUB_URL}/issues`}> open an issue on GitHub</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="container body">
    <aside data-pagefind-ignore>
      <nav aria-label="Contribution paths" class="intent" data-intent>
        <div class="label">I want to…</div>
        {guides.map((g) => (
            <a href={`#${g.id}`}>
              <span class="mono chip">{g.icon}</span>
              {g.label}
            </a>
          ))}
        <a href="#report">
          <span class="mono chip">BUG</span>
          Report a bug or issue
        </a>
      </nav>

      <div class="rail-box">
        <div class="label">Hub standards</div>
        {STANDARDS_LINKS.map(([label, href]) => <a class="rail-link" href={href}>{label}</a>)}
      </div>
    </aside>

    <div class="guides">
      {guides.map((guide) => (
          <article class="guide" id={guide.id}>
            <div class="guide-meta">
              <span class="pill warn">Guide</span>
              <span class="label">{guide.audience}</span>
              <span class="label">· {guide.time}</span>
            </div>
            <h2>{guide.title}</h2>
            <p class="intro">{guide.intro}</p>

            <div class="steps">
              {guide.steps.map((step, i) => (
                <div class="step">
                  <div class="step-rail">
                    <div class="step-n mono">{i + 1}</div>
                    {i < guide.steps.length - 1 && <div class="step-line" />}
                  </div>
                  <div>
                    <h3>{step.title}</h3>
                    <p>{step.body}</p>
                    {step.code && <pre class="mono">{step.code}</pre>}
                  </div>
                </div>
              ))}
            </div>

            <div class="checklist">
              <h3>Pre-submission checklist</h3>
              <ul>
                {guide.checklist.map((item) => (
                  <li>
                    <span aria-hidden="true" class="check">✓</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}

      <article class="guide" id="report">
        <div class="guide-meta">
          <span class="pill warn">Report</span>
          <span class="label">Anyone</span>
          <span class="label">· ~3 minutes</span>
        </div>
        <h2>Report a bug or issue</h2>
        <p class="intro">
          Spotted something off in a dataset, a broken link, or a glitch on this
          site? Tell us. Reports are tracked as GitHub issues and routed to the
          relevant maintainer.
        </p>
        <ul class="kinds">
          {REPORT_KINDS.map(([label, hint]) => (
              <li>
                <b>{label}</b>
                <span>{hint}</span>
              </li>
            ))}
        </ul>
        <p class="report-tip">
          Be specific — what you expected vs what you got, with exact values and
          steps where possible. For data-quality issues, include the dataset id
          from its catalog page.
        </p>
        <a class="btn btn-accent" href={`${GITHUB_URL}/issues`}
          >Open an issue on GitHub</a
        >
      </article>
    </div>
  </section>
</Layout>

<script>
import { scrollSpy } from "@/lib/scrollspy";

// Highlight the guide currently in view in the "I want to…" list
const nav = document.querySelector<HTMLElement>("[data-intent]");
if (nav) scrollSpy(nav);
</script>

<style>
/* Navy hero — on navy, text is white or #63A9FE only */
.hero {
  padding: 48px 0;
  color: #fff;
  background: var(--cdh-blue-950);
}

.hero :global(nav a),
.hero :global(nav li) {
  color: rgb(255 255 255 / 60%);
}

.hero :global(nav span[aria-current]) {
  color: #fff;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 40px;
  align-items: center;
  margin-top: 12px;
}

h1 {
  color: #fff;
}

.hero-lede {
  max-width: 640px;
  margin-top: 12px;
  font-size: 17px;
  line-height: 1.6;
  color: rgb(255 255 255 / 82%);
}

.help-box {
  padding: 18px;
  background: rgb(0 0 0 / 18%);
  border: 1px solid rgb(99 169 254 / 35%);
  border-radius: 6px;
}

.help-box .label {
  color: var(--cdh-blue-300);
}

.help-box p {
  margin-top: 8px;
  font-size: 13px;
  line-height: 1.6;
  color: rgb(255 255 255 / 86%);
}

.help-box a {
  color: var(--cdh-blue-300);
}

.body {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 32px;
  align-items: start;
  padding-top: 32px;
}

aside {
  position: sticky;
  top: 96px;
}

.intent .label {
  margin-bottom: 10px;
  color: var(--text-soft);
}

.intent a {
  display: flex;
  gap: 12px;
  align-items: center;
  padding: 12px 14px;
  margin-bottom: 4px;
  font-size: 14px;
  font-weight: 500;
  color: var(--text);
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
}

.intent a:hover {
  color: var(--cdh-blue-950);
  text-decoration: none;
  border-color: var(--cdh-blue-950);
}

.intent .chip {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  padding: 2px 6px;
  font-size: 10px;
  color: var(--text-mute);
  letter-spacing: 0.06em;
  background: var(--grey-1);
  border-radius: 6px;
}

.intent a[aria-current="true"] {
  font-weight: 600;
  color: #fff;
  background: var(--cdh-blue-950);
  border-color: var(--cdh-blue-950);
}

.intent a[aria-current="true"] .chip {
  color: var(--cdh-blue-300);
  background: rgb(99 169 254 / 18%);
}

.rail-box {
  padding: 16px;
  margin-top: 24px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
}

.rail-box .label {
  margin-bottom: 6px;
  color: var(--text-mute);
}

.rail-link {
  display: block;
  padding: 8px 0;
  font-size: 13px;
  color: var(--text);
  border-bottom: 1px solid var(--border);
}

.rail-link:last-child {
  border-bottom: 0;
}

.rail-link:hover {
  color: var(--cdh-blue-700);
  text-decoration: none;
}

.guides {
  display: flex;
  flex-direction: column;
  gap: 32px;
  min-width: 0;
}

.guide {
  padding: 28px;
  scroll-margin-top: 96px;
  background: var(--surface);
  border: 1px solid var(--border);
}

.guide-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
}

.guide-meta .label {
  color: var(--text-mute);
}

.guide h2 {
  max-width: 720px;
  margin-top: 12px;
  font-size: 30px;
}

.intro {
  max-width: 720px;
  margin-top: 10px;
  font-size: 16px;
  line-height: 1.65;
  color: var(--text-soft);
}

.steps {
  margin-top: 28px;
}

.step {
  display: grid;
  grid-template-columns: 44px 1fr;
  gap: 16px;
  padding: 16px 0;
  border-bottom: 1px solid var(--border);
}

.step:first-child {
  border-top: 1px solid var(--border);
}

.step-rail {
  position: relative;
}

.step-n {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  font-size: 13px;
  font-weight: 700;
  color: var(--cdh-blue-300);
  background: var(--cdh-blue-950);
  border-radius: 50%;
}

.step-line {
  position: absolute;
  top: 36px;
  bottom: -16px;
  left: 15px;
  width: 2px;
  background: var(--border-strong);
}

.step h3 {
  font-family: var(--sans);
  font-size: 17px;
  font-weight: 600;
}

.step p {
  margin-top: 6px;
  font-size: 14px;
  line-height: 1.65;
  color: var(--text-soft);
}

.step pre {
  padding: 12px;
  margin-top: 10px;
  overflow-x: auto;
  font-size: 12px;
  line-height: 1.55;
  color: var(--cdh-blue-300);
  background: var(--cdh-blue-950);
  border-radius: 6px;
}

.checklist {
  margin-top: 28px;
}

.checklist h3 {
  font-size: 22px;
}

.checklist ul {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 0;
  margin: 12px 0 0;
  list-style: none;
}

.checklist li {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  font-size: 14px;
}

.check {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 16px;
  height: 16px;
  margin-top: 2px;
  font-size: 10px;
  font-weight: 700;
  color: var(--cdh-blue-700);
  border: 1.5px solid var(--cdh-blue-700);
  border-radius: 6px;
}

.kinds {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 10px;
  padding: 0;
  margin: 24px 0 0;
  list-style: none;
}

.kinds li {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 12px 14px;
  background: var(--bg);
  border: 1px solid var(--border-strong);
  border-radius: 6px;
}

.kinds b {
  font-size: 14px;
  color: var(--cdh-blue-950);
}

.kinds span {
  font-size: 12px;
  line-height: 1.4;
  color: var(--text-mute);
}

.report-tip {
  max-width: 720px;
  margin-top: 18px;
  font-size: 14px;
  line-height: 1.6;
  color: var(--text-soft);
}

.guide .btn {
  margin-top: 20px;
}

@media (width <= 900px) {
  .hero-grid,
  .body {
    grid-template-columns: 1fr;
  }

  aside {
    position: static;
  }
}
</style>
