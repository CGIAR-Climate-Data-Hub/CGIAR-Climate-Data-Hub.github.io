# Cloudflare Pages response headers — inert on GitHub Pages (served as a
# plain file), active as soon as this build output is served by CF Pages.

# RFC 8288 Link headers for agent discovery (rels registered via RFC 9727)
/*
  Link: </.well-known/api-catalog>; rel="api-catalog", </ai/>; rel="service-doc"

# RFC 9727 requires linkset+json; extensionless files otherwise default to octet-stream
/.well-known/api-catalog
  Content-Type: application/linkset+json

# Astro's /_astro/ assets (JS, CSS, fonts) are content-hashed — a new deploy
# gets new filenames, so these can cache forever. Pagefind's stable-named
# files stay on default caching.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
